@model MARS_Project.Models.User
@{
    ViewBag.Title = "My Profile";
    Layout = "~/Views/Shared/_LayoutCustomer.cshtml";
}

<style>
    /* ─── Page background ─── */
    .profile-page {
        min-height: 100vh;
        background: #f0f2f8;
        padding: 40px 0 60px;
    }

    /* ─── Top hero banner ─── */
    .profile-hero {
        background: linear-gradient(135deg, #1a0a08 0%, #C0392B 60%, #8B1A14 100%);
        padding: 48px 0 90px;
        position: relative;
        overflow: hidden;
    }

        .profile-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        .profile-hero::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 60px;
            background: #f0f2f8;
            clip-path: ellipse(55% 100% at 50% 100%);
        }

    .hero-inner {
        position: relative;
        z-index: 2;
        text-align: center;
        color: #fff;
    }

        .hero-inner .page-label {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.6);
            margin-bottom: 6px;
        }

        .hero-inner h1 {
            font-size: 1.7rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 14px;
        }

    .hero-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 18px;
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 20px;
        color: #fff;
        font-size: 13px;
        text-decoration: none;
        transition: background 0.2s;
    }

        .hero-back-btn:hover {
            background: rgba(255,255,255,0.25);
            color: #fff;
        }

    /* ─── Main card wrapper ─── */
    .profile-wrapper {
        max-width: 720px;
        margin: -60px auto 0;
        padding: 0 16px;
        position: relative;
        z-index: 5;
    }

    /* ─── Avatar + name card ─── */
    .avatar-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.09);
        padding: 32px 28px 28px;
        text-align: center;
        margin-bottom: 20px;
        border: 1px solid #eee;
    }

    .avatar-ring {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        padding: 4px;
        background: linear-gradient(135deg, #C0392B, #E8C97A);
        display: inline-block;
        margin-bottom: 16px;
    }

        .avatar-ring img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #fff;
            display: block;
        }

    .avatar-name {
        font-size: 1.3rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 4px;
    }

    .avatar-email {
        font-size: 13.5px;
        color: #888;
        margin-bottom: 14px;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        background: #e8f8f0;
        color: #1a7a47;
        border: 1px solid #b7e4cc;
    }

        .status-badge.inactive {
            background: #fef3f2;
            color: #9b1c1c;
            border-color: #f5c6cb;
        }

    .status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
    }

    /* ─── Info card ─── */
    .info-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.07);
        border: 1px solid #eee;
        overflow: hidden;
        margin-bottom: 20px;
    }

    .info-card-header {
        padding: 16px 24px;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .info-card-header .hicon {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg, #C0392B, #8B1A14);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 14px;
            flex-shrink: 0;
        }

        .info-card-header h5 {
            font-size: 14px;
            font-weight: 700;
            color: #1a1a2e;
            margin: 0;
        }

    .info-row {
        display: flex;
        align-items: flex-start;
        padding: 15px 24px;
        border-bottom: 1px solid #f8f8f8;
        gap: 14px;
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-row-icon {
        width: 36px;
        height: 36px;
        background: #fef3f2;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #C0392B;
        font-size: 14px;
        flex-shrink: 0;
    }

    .info-row-content {
        flex: 1;
    }

    .info-row-label {
        font-size: 11px;
        font-weight: 600;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 2px;
    }

    .info-row-value {
        font-size: 14px;
        color: #1a1a2e;
        font-weight: 500;
    }

        .info-row-value.muted {
            color: #aaa;
            font-style: italic;
        }

    /* ─── Action buttons ─── */
    .action-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.07);
        border: 1px solid #eee;
        padding: 20px 24px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-edit-profile {
        flex: 1;
        min-width: 140px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 20px;
        background: linear-gradient(135deg, #C0392B, #8B1A14);
        color: #fff;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        border: none;
        transition: opacity 0.2s, transform 0.15s;
    }

        .btn-edit-profile:hover {
            opacity: 0.9;
            color: #fff;
            transform: translateY(-1px);
        }

    .btn-logout-profile {
        flex: 1;
        min-width: 140px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 20px;
        background: transparent;
        color: #C0392B;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        border: 2px solid #C0392B;
        transition: background 0.2s, color 0.2s;
    }

        .btn-logout-profile:hover {
            background: #C0392B;
            color: #fff;
        }

    @@media (max-width: 576px) {
        .profile-hero {
            padding: 36px 0 80px;
        }

        .profile-wrapper {
            margin-top: -50px;
        }

        .info-row {
            padding: 12px 16px;
        }

        .info-card-header {
            padding: 14px 16px;
        }

        .action-card {
            padding: 16px;
            flex-direction: column;
        }
    }
</style>

<!-- Hero Banner -->
<div class="profile-hero">
    <div class="container hero-inner">
        <div class="page-label">Account</div>
        <h1>My Profile</h1>
        <a href="@Url.Action("Index","CustomerProduct")" class="hero-back-btn">
            <i class="fa fa-home"></i> Home
        </a>
    </div>
</div>

<!-- Profile Content -->
<div class="profile-wrapper">

    <!-- Avatar Card -->
    <div class="avatar-card">
        <div class="avatar-ring">
            <img src="@(!string.IsNullOrEmpty(Model.ProfileImage) ? Model.ProfileImage : Url.Content("~/Content/Images/avt.png"))"
                 alt="@Model.Name" />
        </div>
        <div class="avatar-name">@Model.Name</div>
        <div class="avatar-email">@Model.Email</div>
       
    </div>

    <!-- Info Card -->
    <div class="info-card">
        <div class="info-card-header">
            <div class="hicon"><i class="fa fa-user"></i></div>
            <h5>Profile Information</h5>
        </div>

        <div class="info-row">
            <div class="info-row-icon"><i class="fa fa-phone"></i></div>
            <div class="info-row-content">
                <div class="info-row-label">Contact Number</div>
                <div class="info-row-value @(string.IsNullOrEmpty(Model.ContactNumber) ? "muted" : "")">
                    @(string.IsNullOrEmpty(Model.ContactNumber) ? "Not provided" : Model.ContactNumber)
                </div>
            </div>
        </div>

        <div class="info-row">
            <div class="info-row-icon"><i class="fa fa-map-marker-alt"></i></div>
            <div class="info-row-content">
                <div class="info-row-label">Address</div>
                <div class="info-row-value @(string.IsNullOrEmpty(Model.Address) ? "muted" : "")">
                    @(string.IsNullOrEmpty(Model.Address) ? "Not provided" : Model.Address)
                </div>
            </div>
        </div>

        <div class="info-row">
            <div class="info-row-icon"><i class="fa fa-calendar-alt"></i></div>
            <div class="info-row-content">
                <div class="info-row-label">Member Since</div>
                <div class="info-row-value">
                    @(Model.CreatedDate.HasValue ? Model.CreatedDate.Value.ToString("MMMM dd, yyyy") : "—")
                </div>
            </div>
        </div>

        <div class="info-row">
            <div class="info-row-icon"><i class="fa fa-id-badge"></i></div>
            <div class="info-row-content">
                <div class="info-row-label">Account Type</div>
                <div class="info-row-value">Customer</div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="action-card">
        <a href="@Url.Action("EditProfile","CustomerProduct")" class="btn-edit-profile">
            <i class="fa fa-edit"></i> Edit Profile
        </a>
        <a href="@Url.Action("Logout","Home")" class="btn-logout-profile" id="btnLogout">
            <i class="fa fa-sign-out-alt"></i> Logout
        </a>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.getElementById("btnLogout")?.addEventListener("click", function (e) {
        e.preventDefault();
        var href = this.href;
        Swal.fire({
            title: "Logging out?",
            text: "Are you sure you want to log out?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#C0392B",
            cancelButtonColor: "#6c757d",
            confirmButtonText: "Yes, log out",
            cancelButtonText: "Cancel",
            borderRadius: "16px"
        }).then((result) => {
            if (result.isConfirmed) window.location.href = href;
        });
    });
</script>
