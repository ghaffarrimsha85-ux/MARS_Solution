@{
    ViewBag.Title = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - MARS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            background-size: cover;
            background-position: center;
            animation: bgSlide 24s infinite;
            font-family: 'Poppins', sans-serif;
        }

        @@keyframes bgSlide {
            0% { background-image: url('https://images.unsplash.com/photo-1506765515384-028b60a970df'); }
            33% { background-image: url('https://images.unsplash.com/photo-1521737604893-d14cc237f11d'); }
            66% { background-image: url('https://images.unsplash.com/photo-1522202195461-5a8132f0c9b0'); }
            100% { background-image: url('https://images.unsplash.com/photo-1506765515384-028b60a970df'); }
        }

        .form-box {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 20px;
            padding: 40px;
            max-width: 400px;
            margin: 100px auto;
            box-shadow: 0 0 25px rgba(0, 0, 0, 0.3);
            text-align: center;
        }

        h2 { color: #007bff; font-weight: 700; margin-bottom: 20px; }
        .form-control { border-radius: 30px; padding: 12px; }
        .btn-send { border-radius: 30px; padding: 10px; background: #007bff; color: white; width: 100%; font-weight: bold; }
        .btn-send:hover { background: #0056b3; }
        .error { color: #e74c3c; font-weight: 500; margin-bottom: 10px; }
        .success { color: #28a745; font-weight: 500; margin-bottom: 10px; }
    </style>
</head>
<body>

    <div class="form-box">
        <h2>Forgot Password?</h2>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="success">@TempData["SuccessMessage"]</div>
        }
        @if (ViewBag.ErrorMessage != null)
        {
            <div class="error">@ViewBag.ErrorMessage</div>
        }

        <form method="post" action="@Url.Action("ForgotPassword", "Home")">
            <div class="mb-3">
                <input type="email" name="useremail" class="form-control" placeholder="Enter your registered email" required />
            </div>
            <button type="submit" class="btn btn-send">Send Reset Code</button>
        </form>

        <div class="mt-3">
            <a href="@Url.Action("Login", "Home")">Back to Login</a>
        </div>
    </div>

</body>
</html>
