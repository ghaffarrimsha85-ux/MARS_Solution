@{
    ViewBag.Title = "Reset Password";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - MARS</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            background-size: cover;
            background-position: center;
            animation: bgSlide 24s infinite;
            font-family: 'Poppins', sans-serif;
        }

        @@keyframes bgSlide {
            0% { background-image: url('https://images.unsplash.com/photo-1506765515384-028b60a970df'); }
            33% { background-image: url('https://images.unsplash.com/photo-1521737604893-d14cc237f11d'); }
            66% { background-image: url('https://images.unsplash.com/photo-1522202195461-5a8132f0c9b0'); }
            100% { background-image: url('https://images.unsplash.com/photo-1506765515384-028b60a970df'); }
        }

        .form-box {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 25px;
            padding: 40px 35px;
            max-width: 400px;
            width: 90%;
            margin: 90px auto;
            box-shadow: 0 0 25px rgba(0, 0, 0, 0.3);
            text-align: center;
            animation: fadeIn 1s ease-in;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h2 {
            color: #007bff;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .form-control {
            border-radius: 30px;
            padding: 12px;
            font-size: 15px;
        }

        .btn-reset {
            width: 100%;
            border-radius: 30px;
            padding: 10px;
            background: #007bff;
            color: #fff;
            font-weight: bold;
            letter-spacing: 0.5px;
            transition: 0.3s;
        }

        .btn-reset:hover {
            background: #0056b3;
        }

        .alert {
            border-radius: 15px;
            font-size: 14px;
        }

        .footer-link {
            margin-top: 15px;
            display: block;
            font-size: 14px;
        }

        .footer-link a {
            color: #007bff;
            text-decoration: none;
        }

        .footer-link a:hover {
            text-decoration: underline;
        }

        /* Optional glow effect for heading */
        h2 span {
            color: #0056b3;
            text-shadow: 0px 0px 5px rgba(0, 123, 255, 0.6);
        }
    </style>
</head>
<body>

    <div class="container mt-5 d-flex justify-content-center">
        <div class="card shadow-lg p-4" style="width: 400px;">
            <h3 class="text-center mb-3">🔒 Reset Password</h3>

            <form method="post" action="/Home/ResetPassword">
                <input type="hidden" name="email" value="@ViewBag.Email" />
                <input type="hidden" name="code" value="@ViewBag.Code" />

                <div class="mb-3">
                    <label class="form-label">New Password</label>
                    <input type="password" name="newPassword" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Confirm Password</label>
                    <input type="password" name="confirmPassword" class="form-control" required />
                </div>

                <button type="submit" class="btn btn-primary w-100">Reset Password</button>

                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-info mt-3 text-center">@ViewBag.Message</div>
                }
            </form>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
