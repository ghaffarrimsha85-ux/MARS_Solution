@{
    ViewBag.Title = "Dashboard";
    ViewBag.Active = "dashboard";
    Layout = "~/Views/Shared/_LayoutEmployee.cshtml";
}

<style>
    /* ── Welcome banner ── */
    .welcome-banner {
        background: linear-gradient(135deg, #1a0a08 0%, #C0392B 55%, #8B1A14 100%);
        border-radius: 18px;
        padding: 28px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
    }

    .welcome-banner::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
        background-size: 32px 32px;
    }

    .welcome-text { position: relative; z-index: 2; }

    .welcome-text .greet {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.6);
        margin-bottom: 6px;
    }

    .welcome-text h2 {
        font-size: 1.55rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 6px;
    }

    .welcome-text p {
        font-size: 13px;
        color: rgba(255,255,255,0.7);
        margin: 0;
    }

    .welcome-icon-wrap {
        position: relative; z-index: 2;
        width: 72px; height: 72px;
        background: rgba(255,255,255,0.12);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 28px;
        border: 2px solid rgba(255,255,255,0.2);
        flex-shrink: 0;
    }

    /* ── Section label ── */
    .section-label {
        font-size: 12px;
        font-weight: 700;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-label::after { content: ''; flex: 1; height: 1px; background: #eee; }

    /* ── Stat card ── */
    .stat-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #eee;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.05);
        transition: transform 0.18s, box-shadow 0.18s;
        text-decoration: none;
        color: inherit;
        margin-bottom: 16px;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 28px rgba(0,0,0,0.09);
        color: inherit;
    }

    .stat-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .stat-icon.red    { background: #fef3f2; color: #C0392B; }
    .stat-icon.green  { background: #e8f8f0; color: #1a7a47; }
    .stat-icon.amber  { background: #fff8e6; color: #b7770d; }
    .stat-icon.blue   { background: #eef5ff; color: #1a5fa8; }
    .stat-icon.purple { background: #f3eeff; color: #7c3aed; }
    .stat-icon.teal   { background: #e6fafa; color: #0e7490; }

    .stat-info { flex: 1; }

    .stat-label {
        font-size: 11.5px;
        font-weight: 600;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 26px;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1;
        margin-bottom: 4px;
    }

    .stat-sub {
        font-size: 12px;
        color: #bbb;
    }

    .stat-arrow {
        color: #ddd;
        font-size: 14px;
        flex-shrink: 0;
    }

    /* ── Quick links ── */
    .quick-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #eee;
        box-shadow: 0 4px 16px rgba(0,0,0,0.05);
        overflow: hidden;
        margin-bottom: 16px;
    }

    .quick-card-header {
        padding: 14px 18px;
        border-bottom: 1px solid #f0f0f0;
        display: flex; align-items: center; gap: 10px;
        background: #fafafa;
    }

    .quick-card-header .hicon {
        width: 30px; height: 30px;
        background: linear-gradient(135deg, #C0392B, #8B1A14);
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 13px;
    }

    .quick-card-header h6 { font-size: 13.5px; font-weight: 700; color: #1a1a2e; margin: 0; }

    .quick-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px 18px;
        border-bottom: 1px solid #f5f5f5;
        text-decoration: none;
        transition: background 0.15s;
        color: #444;
    }

    .quick-link:last-child { border-bottom: none; }
    .quick-link:hover { background: #fef3f2; color: #C0392B; }

    .quick-link-icon {
        width: 34px; height: 34px;
        border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px;
        flex-shrink: 0;
    }

    .quick-link-icon.red    { background: #fef3f2; color: #C0392B; }
    .quick-link-icon.green  { background: #e8f8f0; color: #1a7a47; }
    .quick-link-icon.amber  { background: #fff8e6; color: #b7770d; }
    .quick-link-icon.blue   { background: #eef5ff; color: #1a5fa8; }
    .quick-link-icon.purple { background: #f3eeff; color: #7c3aed; }

    .quick-link-text { flex: 1; font-size: 13.5px; font-weight: 500; }
    .quick-link-arrow { font-size: 12px; color: #ccc; }
    .quick-link:hover .quick-link-arrow { color: #C0392B; }

    /* ── Activity note ── */
    .activity-note {
        background: linear-gradient(135deg, #fff8e6, #fff);
        border: 1px solid rgba(183,119,13,0.18);
        border-radius: 12px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        font-size: 13px;
        color: #666;
    }

    .activity-note i { color: #b7770d; font-size: 16px; flex-shrink: 0; }

    @@media(max-width:576px) {
        .welcome-banner { flex-direction: column; padding: 22px 20px; }
        .welcome-icon-wrap { width: 54px; height: 54px; font-size: 22px; }
    }
</style>

<!-- Welcome Banner -->
<div class="welcome-banner">
    <div class="welcome-text">
        <div class="greet">Employee Panel</div>
        <h2>Welcome back, @Session["UserName"]! 👋</h2>
        <p>Here's your dashboard overview for today — @DateTime.Now.ToString("MMMM dd, yyyy")</p>
    </div>
    <div class="welcome-icon-wrap">
        <i class="fa fa-user-tie"></i>
    </div>
</div>

<!-- Activity note -->
<div class="activity-note">
    <i class="fa fa-circle-info"></i>
    Check your assigned repair requests regularly and respond on time to keep customer satisfaction high.
</div>

<!-- Stats Grid -->
<div class="section-label">Overview Statistics</div>

<div class="row g-0">
    <div class="col-sm-6 col-lg-4 pe-lg-2">
        <a href="@Url.Action("RequestsList","Employee")" class="stat-card">
            <div class="stat-icon amber"><i class="fa fa-envelope"></i></div>
            <div class="stat-info">
                <div class="stat-label">Total Requests</div>
                <div class="stat-value">@(ViewBag.TotalRequests ?? 0)</div>
                <div class="stat-sub">All repair requests</div>
            </div>
            <div class="stat-arrow"><i class="fa fa-chevron-right"></i></div>
        </a>
    </div>

    <div class="col-sm-6 col-lg-4 px-lg-2">
        <a href="@Url.Action("ProductList","Employee")" class="stat-card">
            <div class="stat-icon green"><i class="fa fa-mobile-alt"></i></div>
            <div class="stat-info">
                <div class="stat-label">Products</div>
                <div class="stat-value">@(ViewBag.TotalProducts ?? 0)</div>
                <div class="stat-sub">In inventory</div>
            </div>
            <div class="stat-arrow"><i class="fa fa-chevron-right"></i></div>
        </a>
    </div>

    <div class="col-sm-6 col-lg-4 ps-lg-2">
        <a href="@Url.Action("CustomerList","Employee")" class="stat-card">
            <div class="stat-icon blue"><i class="fa fa-users"></i></div>
            <div class="stat-info">
                <div class="stat-label">Customers</div>
                <div class="stat-value">@(ViewBag.TotalCustomers ?? 0)</div>
                <div class="stat-sub">Registered customers</div>
            </div>
            <div class="stat-arrow"><i class="fa fa-chevron-right"></i></div>
        </a>
    </div>

    <div class="col-sm-6 col-lg-4 pe-lg-2">
        <a href="@Url.Action("AssignedRequests","Employee")" class="stat-card">
            <div class="stat-icon red"><i class="fa fa-wrench"></i></div>
            <div class="stat-info">
                <div class="stat-label">Assigned to Me</div>
                <div class="stat-value">@(ViewBag.TotalReports ?? 0)</div>
                <div class="stat-sub">Pending repairs</div>
            </div>
            <div class="stat-arrow"><i class="fa fa-chevron-right"></i></div>
        </a>
    </div>

    <div class="col-sm-6 col-lg-4 px-lg-2">
        <a href="@Url.Action("MyResponses","Employee")" class="stat-card">
            <div class="stat-icon purple"><i class="fa fa-reply"></i></div>
            <div class="stat-info">
                <div class="stat-label">My Responses</div>
                <div class="stat-value">@(ViewBag.TotalEmployees ?? 0)</div>
                <div class="stat-sub">Responses submitted</div>
            </div>
            <div class="stat-arrow"><i class="fa fa-chevron-right"></i></div>
        </a>
    </div>

    <div class="col-sm-6 col-lg-4 ps-lg-2">
        <a href="@Url.Action("Reports","Employee")" class="stat-card">
            <div class="stat-icon teal"><i class="fa fa-chart-line"></i></div>
            <div class="stat-info">
                <div class="stat-label">Users</div>
                <div class="stat-value">@(ViewBag.TotalUsers ?? 0)</div>
                <div class="stat-sub">Total system users</div>
            </div>
            <div class="stat-arrow"><i class="fa fa-chevron-right"></i></div>
        </a>
    </div>
</div>

<!-- Quick Actions -->
<div class="section-label" style="margin-top: 8px;">Quick Actions</div>

<div class="row">
    <div class="col-md-6">
        <div class="quick-card">
            <div class="quick-card-header">
                <div class="hicon"><i class="fa fa-bolt"></i></div>
                <h6>My Work</h6>
            </div>
            <a href="@Url.Action("AssignedRequests","Employee")" class="quick-link">
                <div class="quick-link-icon red"><i class="fa fa-wrench"></i></div>
                <span class="quick-link-text">Assigned Repair Requests</span>
                <i class="fa fa-chevron-right quick-link-arrow"></i>
            </a>
            <a href="@Url.Action("MyResponses","Employee")" class="quick-link">
                <div class="quick-link-icon purple"><i class="fa fa-reply"></i></div>
                <span class="quick-link-text">My Responses</span>
                <i class="fa fa-chevron-right quick-link-arrow"></i>
            </a>
            <a href="@Url.Action("Reports","Employee")" class="quick-link">
                <div class="quick-link-icon amber"><i class="fa fa-chart-line"></i></div>
                <span class="quick-link-text">View Reports</span>
                <i class="fa fa-chevron-right quick-link-arrow"></i>
            </a>
        </div>
    </div>

    <div class="col-md-6">
        <div class="quick-card">
            <div class="quick-card-header">
                <div class="hicon"><i class="fa fa-list"></i></div>
                <h6>Overview</h6>
            </div>
            <a href="@Url.Action("ProductList","Employee")" class="quick-link">
                <div class="quick-link-icon green"><i class="fa fa-mobile-alt"></i></div>
                <span class="quick-link-text">Product List</span>
                <i class="fa fa-chevron-right quick-link-arrow"></i>
            </a>
            <a href="@Url.Action("RequestsList","Employee")" class="quick-link">
                <div class="quick-link-icon amber"><i class="fa fa-list-check"></i></div>
                <span class="quick-link-text">All Repair Requests</span>
                <i class="fa fa-chevron-right quick-link-arrow"></i>
            </a>
            <a href="@Url.Action("CustomerList","Employee")" class="quick-link">
                <div class="quick-link-icon blue"><i class="fa fa-users"></i></div>
                <span class="quick-link-text">Customer List</span>
                <i class="fa fa-chevron-right quick-link-arrow"></i>
            </a>
        </div>
    </div>
</div>
