@model IEnumerable<MARS_Project.Models.RepairRequest>
@{
    ViewBag.Title = "Assigned Repair Requests";
    Layout = "~/Views/Shared/_LayoutEmployee.cshtml"; // (create this like your customer layout)
}

<!-- 🌟 Hero Section -->
<section class="hero-section text-center text-white d-flex align-items-center justify-content-center"
         style="background: url('/Content/Images/bn3.jpeg') center/cover no-repeat; height: 220px;">
    <div class="overlay"></div>
    <div class="container position-relative">
        <h1 class="fw-bold">@ViewBag.Title</h1>
    </div>
</section>

<div class="container mt-5">
    <h3 class="fw-bold mb-3"><i class="fa fa-tools me-2"></i> My Assigned Repairs</h3>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">No repair requests assigned yet.</div>
    }
    else
    {
        <table class="table table-hover align-middle shadow-sm">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in Model)
                {
                    <tr>
                        <td>@req.RequestID</td>
                        <td>@req.User?.Name</td>
                        <td>@req.ProblemDescription</td>
                        <td>
                            @if (req.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                            else if (req.Status == "In Progress")
                            {
                                <span class="badge bg-info text-dark">In Progress</span>
                            }
                            else if (req.Status == "Completed")
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@req.Status</span>
                            }
                        </td>
                        <td>@req.RequestDate?.ToString("dd-MMM-yyyy")</td>
                        <td>
                            <a href="@Url.Action("Details", "Employee", new { id = req.RequestID })"
                               class="btn btn-outline-primary btn-sm rounded-circle" title="View Details">
                                <i class="fa fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @if (TempData["Message"] != null)
    {
        <text>
            Swal.fire({
            icon: 'success',
            title: 'Success',
            text: '@TempData["Message"]',
            confirmButtonColor: '#3085d6'
            });
        </text>
    }
}
