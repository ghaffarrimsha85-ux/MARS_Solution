@model MARS_Project.Models.User
@{
    ViewBag.Title = "Edit Profile";
    ViewBag.Active = "profile";
    Layout = "~/Views/Shared/_LayoutEmployee.cshtml";
}

<style>
    .page-title { font-size:1.2rem; font-weight:700; color:#1a1a2e; margin-bottom:3px; }
    .page-sub   { font-size:12.5px; color:#aaa; margin-bottom:22px; }

    .edit-wrapper { max-width:680px; margin:0 auto; }

    /* Avatar card */
    .avatar-card {
        background:#fff; border-radius:18px;
        border:1px solid #eee;
        box-shadow:0 4px 20px rgba(0,0,0,0.06);
        padding:26px; text-align:center;
        margin-bottom:16px;
    }

    .avatar-ring {
        width:100px; height:100px;
        border-radius:50%;
        padding:3px;
        background:linear-gradient(135deg,#C0392B,#E8C97A);
        display:inline-block;
        margin-bottom:14px;
    }

    .avatar-ring img {
        width:100%; height:100%;
        border-radius:50%;
        object-fit:cover;
        border:3px solid #fff;
        display:block;
    }

    .photo-btn {
        display:inline-flex; align-items:center; gap:6px;
        padding:8px 18px;
        background:transparent;
        border:2px solid #C0392B;
        border-radius:20px;
        color:#C0392B;
        font-size:13px; font-weight:600;
        cursor:pointer;
        transition:background 0.2s,color 0.2s;
    }
    .photo-btn:hover { background:#C0392B; color:#fff; }
    .photo-hint { font-size:11.5px; color:#bbb; margin-top:7px; }

    /* Form card */
    .form-card {
        background:#fff; border-radius:18px;
        border:1px solid #eee;
        box-shadow:0 4px 20px rgba(0,0,0,0.06);
        overflow:hidden; margin-bottom:14px;
    }

    .form-card-header {
        padding:14px 22px; border-bottom:1px solid #f0f0f0;
        background:#fafafa; display:flex; align-items:center; gap:10px;
    }

    .form-card-header .hicon {
        width:32px; height:32px;
        background:linear-gradient(135deg,#C0392B,#8B1A14);
        border-radius:9px; display:flex; align-items:center; justify-content:center;
        color:#fff; font-size:13px;
    }

    .form-card-header h6 { font-size:13.5px; font-weight:700; color:#1a1a2e; margin:0; }
    .form-card-body { padding:22px; }

    /* Fields */
    .fields-grid { display:grid; grid-template-columns:1fr 1fr; gap:0 18px; }
    .field-group { margin-bottom:18px; }
    .field-group.full { grid-column:1/-1; }
    .field-group label { display:block; font-size:11px; font-weight:600; color:#888; text-transform:uppercase; letter-spacing:0.7px; margin-bottom:6px; }
    .field-wrap { position:relative; }
    .field-wrap .f-icon { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#C0392B; font-size:13px; pointer-events:none; }
    .field-wrap .f-icon-top { position:absolute; left:12px; top:12px; color:#C0392B; font-size:13px; pointer-events:none; }
    .field-wrap input, .field-wrap textarea {
        width:100%; padding:10px 13px 10px 37px;
        border:1.5px solid #e5e7eb; border-radius:10px;
        font-size:13.5px; color:#1a1a2e;
        background:#fdfdfd; outline:none;
        font-family:'DM Sans',sans-serif;
        transition:border-color 0.2s, box-shadow 0.2s;
    }
    .field-wrap textarea { resize:none; height:80px; padding-top:10px; }
    .field-wrap input:focus, .field-wrap textarea:focus {
        border-color:#C0392B;
        box-shadow:0 0 0 3px rgba(192,57,43,0.1);
        background:#fff;
    }
    .field-wrap input[readonly] { background:#f5f5f5; color:#aaa; cursor:not-allowed; }
    .readonly-hint { font-size:10.5px; color:#bbb; margin-top:3px; }

    /* Action card */
    .action-card {
        background:#fff; border-radius:18px;
        border:1px solid #eee;
        box-shadow:0 4px 20px rgba(0,0,0,0.06);
        padding:18px 22px;
        display:flex; align-items:center; justify-content:space-between;
        flex-wrap:wrap; gap:12px;
    }

    .btn-save {
        display:inline-flex; align-items:center; gap:7px;
        padding:11px 28px;
        background:linear-gradient(135deg,#C0392B,#8B1A14);
        color:#fff; border:none; border-radius:11px;
        font-size:14px; font-weight:700; cursor:pointer;
        box-shadow:0 4px 14px rgba(192,57,43,0.3);
        transition:opacity 0.2s, transform 0.15s;
    }
    .btn-save:hover { opacity:0.9; transform:translateY(-1px); }

    .btn-cancel {
        display:inline-flex; align-items:center; gap:6px;
        padding:10px 20px;
        background:transparent; color:#555;
        border:1.5px solid #e0e0e0; border-radius:11px;
        font-size:13.5px; font-weight:600;
        text-decoration:none;
        transition:border-color 0.2s, color 0.2s;
    }
    .btn-cancel:hover { border-color:#C0392B; color:#C0392B; }

    .btn-chpwd {
        display:inline-flex; align-items:center; gap:6px;
        padding:10px 18px;
        background:#fff8e6; color:#b7770d;
        border:1.5px solid #f5d87a; border-radius:11px;
        font-size:13px; font-weight:600;
        text-decoration:none;
        transition:background 0.2s;
    }
    .btn-chpwd:hover { background:#f5d87a; color:#7a5000; }

    @@media(max-width:540px) {
        .fields-grid { grid-template-columns:1fr; }
        .field-group.full { grid-column:auto; }
        .form-card-body { padding:16px; }
        .action-card { flex-direction:column; }
        .btn-save, .btn-cancel, .btn-chpwd { width:100%; justify-content:center; }
    }
</style>

<div class="page-title"><i class="fa fa-user-pen me-2" style="color:#C0392B;"></i>Edit Profile</div>
<div class="page-sub">Update your personal information</div>

<div class="edit-wrapper">
    @using (Html.BeginForm("EditProfile", "Employee", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()

        <!-- Avatar upload -->
        <div class="avatar-card">
            <div class="avatar-ring">
                <img id="imgPreview"
                     src="@(!string.IsNullOrEmpty(Model.ProfileImage) ? Url.Content(Model.ProfileImage) : Url.Content("~/Content/Images/default-profile.png"))"
                     alt="Profile Photo" />
            </div>
            <div>
                <label class="photo-btn">
                    <i class="fa fa-camera"></i> Change Photo
                    <input type="file" name="ProfileImageFile" accept="image/*"
                           onchange="previewImage(this)" hidden />
                </label>
            </div>
            <div class="photo-hint">JPG, PNG — max 2MB recommended</div>
        </div>

        <!-- Personal info -->
        <div class="form-card">
            <div class="form-card-header">
                <div class="hicon"><i class="fa fa-user"></i></div>
                <h6>Personal Information</h6>
            </div>
            <div class="form-card-body">
                <div class="fields-grid">

                    <div class="field-group full">
                        <label>Full Name</label>
                        <div class="field-wrap">
                            <i class="fa fa-user f-icon"></i>
                            @Html.TextBoxFor(m => m.Name, new { placeholder = "Your full name" })
                        </div>
                    </div>

                    <div class="field-group full">
                        <label>Email Address</label>
                        <div class="field-wrap">
                            <i class="fa fa-envelope f-icon"></i>
                            @Html.TextBoxFor(m => m.Email, new { placeholder = "Email", @readonly = "readonly" })
                        </div>
                        <div class="readonly-hint"><i class="fa fa-lock"></i> Email cannot be changed</div>
                    </div>

                    <div class="field-group">
                        <label>Contact Number</label>
                        <div class="field-wrap">
                            <i class="fa fa-phone f-icon"></i>
                            @Html.TextBoxFor(m => m.ContactNumber, new { placeholder = "03xx-xxxxxxx" })
                        </div>
                    </div>

                    <div class="field-group">
                        <label>Address</label>
                        <div class="field-wrap">
                            <i class="fa fa-map-marker-alt f-icon-top"></i>
                            @Html.TextAreaFor(m => m.Address, new { placeholder = "Your address", style = "padding-left:37px;" })
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="action-card">
            <div style="display:flex;gap:10px;flex-wrap:wrap;">
                <a href="@Url.Action("Profile","Employee")" class="btn-cancel">
                    <i class="fa fa-arrow-left"></i> Cancel
                </a>
                <a href="@Url.Action("ChangePassword","Employee")" class="btn-chpwd">
                    <i class="fa fa-key"></i> Change Password
                </a>
            </div>
            <button type="submit" class="btn-save">
                <i class="fa fa-save"></i> Save Changes
            </button>
        </div>
    }
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imgPreview').src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        @if (TempData["Message"] != null)
        {
            <text>
            Swal.fire({ icon:'success', title:'Updated!', text:'@TempData["Message"]', confirmButtonColor:'#C0392B', timer:2500 });
            </text>
        }
    </script>
}
