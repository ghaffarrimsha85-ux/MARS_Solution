@model MARS_Project.Models.User
@{
    ViewBag.Title = "Change Password";
    ViewBag.Active = "profile";
    Layout = "~/Views/Shared/_LayoutEmployee.cshtml";
}

<style>
    .page-title { font-size:1.2rem; font-weight:700; color:#1a1a2e; margin-bottom:3px; }
    .page-sub   { font-size:12.5px; color:#aaa; margin-bottom:22px; }

    .pwd-wrapper { max-width:480px; margin:0 auto; }

    /* Info banner */
    .info-banner {
        background:linear-gradient(135deg,#fff8e6,#fff);
        border:1px solid rgba(183,119,13,0.2);
        border-radius:14px;
        padding:14px 18px;
        display:flex; align-items:flex-start; gap:12px;
        margin-bottom:18px;
    }
    .info-banner i { color:#b7770d; font-size:16px; flex-shrink:0; margin-top:1px; }
    .info-banner p { font-size:12.5px; color:#666; margin:0; line-height:1.5; }

    /* Form card */
    .pwd-card {
        background:#fff; border-radius:18px;
        border:1px solid #eee;
        box-shadow:0 4px 20px rgba(0,0,0,0.06);
        overflow:hidden; margin-bottom:14px;
    }

    .pwd-card-header {
        padding:14px 22px; border-bottom:1px solid #f0f0f0;
        background:#fafafa; display:flex; align-items:center; gap:10px;
    }

    .pwd-card-header .hicon {
        width:32px; height:32px;
        background:linear-gradient(135deg,#C0392B,#8B1A14);
        border-radius:9px; display:flex; align-items:center; justify-content:center;
        color:#fff; font-size:13px;
    }

    .pwd-card-header h6 { font-size:13.5px; font-weight:700; color:#1a1a2e; margin:0; }
    .pwd-card-body { padding:22px; }

    /* Fields */
    .field-group { margin-bottom:18px; }
    .field-group:last-child { margin-bottom:0; }
    .field-group label { display:block; font-size:11px; font-weight:600; color:#888; text-transform:uppercase; letter-spacing:0.7px; margin-bottom:6px; }

    .field-wrap { position:relative; }
    .field-wrap .f-icon { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#C0392B; font-size:13px; pointer-events:none; }
    .field-wrap input {
        width:100%; padding:11px 42px 11px 37px;
        border:1.5px solid #e5e7eb; border-radius:10px;
        font-size:13.5px; color:#1a1a2e;
        background:#fdfdfd; outline:none;
        font-family:'DM Sans',sans-serif;
        transition:border-color 0.2s, box-shadow 0.2s;
    }
    .field-wrap input:focus {
        border-color:#C0392B;
        box-shadow:0 0 0 3px rgba(192,57,43,0.1);
        background:#fff;
    }

    /* Eye toggle */
    .eye-btn {
        position:absolute; right:11px; top:50%; transform:translateY(-50%);
        background:none; border:none; cursor:pointer; padding:2px;
        display:flex; align-items:center;
        color:#bbb; transition:color 0.18s;
    }
    .eye-btn:hover { color:#C0392B; }
    .eye-btn i { font-size:13px; }

    /* Password strength */
    .strength-wrap { margin-top:6px; }
    .strength-bar { height:3px; border-radius:2px; background:#f0f0f0; overflow:hidden; }
    .strength-fill { height:100%; border-radius:2px; width:0; transition:width 0.3s, background 0.3s; }
    .strength-label { font-size:10.5px; color:#aaa; margin-top:3px; }

    /* Action card */
    .action-card {
        background:#fff; border-radius:18px;
        border:1px solid #eee;
        box-shadow:0 4px 20px rgba(0,0,0,0.06);
        padding:18px 22px;
        display:flex; align-items:center;
        justify-content:space-between;
        flex-wrap:wrap; gap:12px;
    }

    .btn-save-pwd {
        display:inline-flex; align-items:center; gap:7px;
        padding:11px 28px;
        background:linear-gradient(135deg,#C0392B,#8B1A14);
        color:#fff; border:none; border-radius:11px;
        font-size:14px; font-weight:700; cursor:pointer;
        box-shadow:0 4px 14px rgba(192,57,43,0.28);
        transition:opacity 0.2s, transform 0.15s;
    }
    .btn-save-pwd:hover { opacity:0.9; transform:translateY(-1px); }

    .btn-back-pwd {
        display:inline-flex; align-items:center; gap:6px;
        padding:10px 20px; background:transparent; color:#555;
        border:1.5px solid #e0e0e0; border-radius:11px;
        font-size:13.5px; font-weight:600; text-decoration:none;
        transition:border-color 0.2s, color 0.2s;
    }
    .btn-back-pwd:hover { border-color:#C0392B; color:#C0392B; }

    @@media(max-width:480px) {
        .action-card { flex-direction:column; }
        .btn-save-pwd, .btn-back-pwd { width:100%; justify-content:center; }
    }
</style>

<div class="page-title"><i class="fa fa-key me-2" style="color:#C0392B;"></i>Change Password</div>
<div class="page-sub">Update your account password securely</div>

<div class="pwd-wrapper">

    <!-- Info banner -->
    <div class="info-banner">
        <i class="fa fa-shield-halved"></i>
        <p>Choose a strong password with at least 8 characters, including uppercase letters, numbers and symbols.</p>
    </div>

    @using (Html.BeginForm("ChangePassword", "Employee", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="pwd-card">
            <div class="pwd-card-header">
                <div class="hicon"><i class="fa fa-lock"></i></div>
                <h6>Password Details</h6>
            </div>
            <div class="pwd-card-body">

                <!-- Current Password -->
                <div class="field-group">
                    <label>Current Password</label>
                    <div class="field-wrap">
                        <i class="fa fa-lock f-icon"></i>
                        <input type="password" name="CurrentPassword" id="curPwd" placeholder="Enter current password" required />
                        <button type="button" class="eye-btn" onclick="toggleEye('curPwd','eyeCur')">
                            <i class="fa fa-eye" id="eyeCur"></i>
                        </button>
                    </div>
                </div>

                <!-- New Password -->
                <div class="field-group">
                    <label>New Password</label>
                    <div class="field-wrap">
                        <i class="fa fa-lock-open f-icon"></i>
                        <input type="password" name="NewPassword" id="newPwd" placeholder="Create new password" required />
                        <button type="button" class="eye-btn" onclick="toggleEye('newPwd','eyeNew')">
                            <i class="fa fa-eye" id="eyeNew"></i>
                        </button>
                    </div>
                    <div class="strength-wrap">
                        <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                        <div class="strength-label" id="strengthLabel"></div>
                    </div>
                </div>

                <!-- Confirm Password -->
                <div class="field-group">
                    <label>Confirm New Password</label>
                    <div class="field-wrap">
                        <i class="fa fa-check-circle f-icon"></i>
                        <input type="password" name="ConfirmPassword" id="confPwd" placeholder="Re-enter new password" required />
                        <button type="button" class="eye-btn" onclick="toggleEye('confPwd','eyeConf')">
                            <i class="fa fa-eye" id="eyeConf"></i>
                        </button>
                    </div>
                    <div class="strength-label" id="matchLabel" style="margin-top:4px;"></div>
                </div>

            </div>
        </div>

        <div class="action-card">
            <a href="@Url.Action("Profile","Employee")" class="btn-back-pwd">
                <i class="fa fa-arrow-left"></i> Back to Profile
            </a>
            <button type="submit" class="btn-save-pwd">
                <i class="fa fa-save"></i> Save Password
            </button>
        </div>
    }

</div>

@section Scripts {
    <script>
        // Toggle eye
        function toggleEye(inputId, iconId) {
            var inp  = document.getElementById(inputId);
            var icon = document.getElementById(iconId);
            if (inp.type === 'password') {
                inp.type = 'text';
                icon.className = 'fa fa-eye-slash';
            } else {
                inp.type = 'password';
                icon.className = 'fa fa-eye';
            }
        }

        // Password strength
        document.getElementById('newPwd').addEventListener('input', function () {
            var v = this.value;
            var s = 0;
            if (v.length >= 6) s++;
            if (v.length >= 10) s++;
            if (/[A-Z]/.test(v)) s++;
            if (/[0-9]/.test(v)) s++;
            if (/[^A-Za-z0-9]/.test(v)) s++;
            var pcts  = ['0%','25%','45%','70%','90%','100%'];
            var clrs  = ['#ccc','#e74c3c','#e67e22','#f1c40f','#2ecc71','#27ae60'];
            var lbls  = ['','Weak','Fair','Good','Strong','Very Strong'];
            var fill  = document.getElementById('strengthFill');
            var label = document.getElementById('strengthLabel');
            fill.style.width      = v.length ? pcts[s] : '0%';
            fill.style.background = clrs[s];
            label.textContent     = v.length ? lbls[s] : '';
            label.style.color     = clrs[s];
        });

        // Match check
        document.getElementById('confPwd').addEventListener('input', function () {
            var newV  = document.getElementById('newPwd').value;
            var label = document.getElementById('matchLabel');
            if (this.value.length === 0) { label.textContent = ''; return; }
            if (this.value === newV) {
                label.textContent = '✓ Passwords match';
                label.style.color = '#27ae60';
            } else {
                label.textContent = '✗ Passwords do not match';
                label.style.color = '#C0392B';
            }
        });

        // SweetAlert messages
        @if (TempData["Message"] != null)
        {
            var msg = TempData["Message"].ToString();
            var icon = msg.Contains("successfully") ? "success" : "warning";
            <text>
            Swal.fire({
                icon: '@icon',
                title: '@(icon == "success" ? "Done!" : "Notice")',
                text: '@msg',
                confirmButtonColor: '#C0392B',
                timer: 2800,
                timerProgressBar: true
            });
            </text>
        }
    </script>
}
