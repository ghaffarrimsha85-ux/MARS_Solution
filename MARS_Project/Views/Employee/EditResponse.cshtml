@model MARS_Project.Models.RepairResponse
@{
    ViewBag.Title = "Edit Response";
    Layout = "~/Views/Shared/_LayoutEmployee.cshtml";
}

<section class="hero-section text-center text-white d-flex align-items-center justify-content-center"
         style="background: url('/Content/Images/bn2.jpeg') center/cover no-repeat; height: 220px;">
    <div class="overlay"></div>
    <div class="container position-relative">
        <h1 class="fw-bold">@ViewBag.Title</h1>
        <a href="@Url.Action("MyResponses","Employee")" class="btn btn-outline-light mt-2">
            <i class="fa fa-arrow-left"></i> Back to Responses
        </a>
    </div>
</section>

<div class="container mt-5 mb-5">
    <div class="card shadow border-0">
        <div class="card-body">
            <h4 class="fw-bold text-primary mb-3">Edit Repair Response</h4>

            @using (Html.BeginForm("EditResponse", "Employee", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.ResponseID)

                <div class="mb-3">
                    <label class="form-label fw-semibold">Solution Description</label>
                    @Html.TextAreaFor(m => m.SolutionDesc, new { @class = "form-control", rows = "4" })
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Estimated Cost (Rs.)</label>
                        @Html.TextBoxFor(m => m.EstimatedCost, new { @class = "form-control", type = "number" })
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Estimated Time</label>
                        @Html.TextBoxFor(m => m.EstimatedTime, new { @class = "form-control", placeholder = "e.g. 2 days" })
                    </div>
                </div>

                <button type="submit" class="btn btn-success px-4">
                    <i class="fa fa-save"></i> Update Response
                </button>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["Message"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["Message"]',
                confirmButtonColor: '#3085d6'
            });
        </script>
    }
}
