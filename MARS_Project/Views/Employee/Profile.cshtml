@model MARS_Project.Models.User
@{
    ViewBag.Title = "My Profile";
    ViewBag.Active = "profile";
    Layout = "~/Views/Shared/_LayoutEmployee.cshtml";
}

<style>
    .page-title { font-size:1.2rem; font-weight:700; color:#1a1a2e; margin-bottom:3px; }
    .page-sub   { font-size:12.5px; color:#aaa; margin-bottom:22px; }

    .profile-wrapper { max-width:680px; margin:0 auto; }

    /* ── Avatar card ── */
    .avatar-card {
        background:#fff;
        border-radius:18px;
        border:1px solid #eee;
        box-shadow:0 4px 20px rgba(0,0,0,0.06);
        padding:28px 24px;
        text-align:center;
        margin-bottom:16px;
        position:relative;
        overflow:hidden;
    }

    /* subtle top accent */
    .avatar-card::before {
        content:'';
        position:absolute;
        top:0; left:0; right:0;
        height:5px;
        background:linear-gradient(90deg,#C0392B,#E8C97A);
    }

    .avatar-ring {
        width:100px; height:100px;
        border-radius:50%;
        padding:3px;
        background:linear-gradient(135deg,#C0392B,#E8C97A);
        display:inline-block;
        margin-bottom:14px;
    }

    .avatar-ring img {
        width:100%; height:100%;
        border-radius:50%;
        object-fit:cover;
        border:3px solid #fff;
        display:block;
    }

    .profile-name  { font-size:1.2rem; font-weight:700; color:#1a1a2e; margin-bottom:4px; }
    .profile-role  { font-size:12px; color:#aaa; font-weight:500; margin-bottom:12px; letter-spacing:0.5px; }

    .status-badge {
        display:inline-flex; align-items:center; gap:5px;
        padding:4px 14px; border-radius:20px;
        font-size:12px; font-weight:700;
    }
    .status-badge.active   { background:#e8f8f0; color:#1a7a47; border:1px solid #b7e4cc; }
    .status-badge.pending  { background:#fff8e6; color:#b7770d; border:1px solid #f5d87a; }
    .status-badge.inactive { background:#fef3f2; color:#C0392B; border:1px solid rgba(192,57,43,0.25); }
    .status-dot { width:7px; height:7px; border-radius:50%; background:currentColor; }

    /* ── Info card ── */
    .info-card {
        background:#fff; border-radius:18px;
        border:1px solid #eee;
        box-shadow:0 4px 20px rgba(0,0,0,0.06);
        overflow:hidden; margin-bottom:16px;
    }

    .info-header {
        padding:14px 22px; border-bottom:1px solid #f0f0f0;
        background:#fafafa; display:flex; align-items:center; gap:10px;
    }

    .info-header .hicon {
        width:32px; height:32px;
        background:linear-gradient(135deg,#C0392B,#8B1A14);
        border-radius:9px; display:flex; align-items:center; justify-content:center;
        color:#fff; font-size:13px;
    }

    .info-header h6 { font-size:13.5px; font-weight:700; color:#1a1a2e; margin:0; }

    .info-row {
        display:flex; align-items:center; gap:14px;
        padding:14px 22px;
        border-bottom:1px solid #f8f8f8;
    }

    .info-row:last-child { border-bottom:none; }
    .info-row:hover { background:#fefefe; }

    .info-row-icon {
        width:36px; height:36px;
        background:#fef3f2; border-radius:9px;
        display:flex; align-items:center; justify-content:center;
        color:#C0392B; font-size:14px; flex-shrink:0;
    }

    .info-row-label { font-size:10.5px; font-weight:600; color:#aaa; text-transform:uppercase; letter-spacing:0.7px; margin-bottom:2px; }
    .info-row-value { font-size:13.5px; color:#1a1a2e; font-weight:500; }
    .info-row-value.muted { color:#bbb; font-style:italic; }

    /* ── Action card ── */
    .action-card {
        background:#fff; border-radius:18px;
        border:1px solid #eee;
        box-shadow:0 4px 20px rgba(0,0,0,0.06);
        padding:18px 22px;
        display:flex; align-items:center;
        justify-content:space-between;
        flex-wrap:wrap; gap:12px;
    }

    .btn-edit-p {
        display:inline-flex; align-items:center; gap:7px;
        padding:10px 22px;
        background:linear-gradient(135deg,#C0392B,#8B1A14);
        color:#fff; border-radius:11px;
        font-size:13.5px; font-weight:600;
        text-decoration:none;
        box-shadow:0 4px 14px rgba(192,57,43,0.28);
        transition:opacity 0.2s, transform 0.15s;
    }
    .btn-edit-p:hover { opacity:0.9; color:#fff; transform:translateY(-1px); }

    .btn-logout-p {
        display:inline-flex; align-items:center; gap:7px;
        padding:10px 22px;
        background:transparent;
        color:#C0392B; border:2px solid #C0392B;
        border-radius:11px;
        font-size:13.5px; font-weight:600;
        text-decoration:none;
        transition:background 0.2s, color 0.2s;
    }
    .btn-logout-p:hover { background:#C0392B; color:#fff; }

    @@media(max-width:480px) {
        .action-card { flex-direction:column; }
        .btn-edit-p, .btn-logout-p { width:100%; justify-content:center; }
    }
</style>

<div class="page-title"><i class="fa fa-user me-2" style="color:#C0392B;"></i>My Profile</div>
<div class="page-sub">Your personal account information</div>

<div class="profile-wrapper">

    <!-- Avatar card -->
    <div class="avatar-card">
        <div class="avatar-ring">
            <img src="@(!string.IsNullOrEmpty(Model.ProfileImage) ? Url.Content(Model.ProfileImage) : Url.Content("~/Content/Images/avt.png"))"
                 alt="@Model.Name" />
        </div>
        <div class="profile-name">@Model.Name</div>
        <div class="profile-role">Employee · MARS Mobile Shop</div>

        @{
            string st = Model.Status?.ToLower();
            string sbClass = (st == "active" || st == "approved") ? "active" : st == "pending" ? "pending" : "inactive";
            string sbLabel = (st == "active" || st == "approved") ? "Active" : st == "pending" ? "Pending" : "Inactive";
        }
        <span class="status-badge @sbClass">
            <span class="status-dot"></span> @sbLabel
        </span>
    </div>

    <!-- Info card -->
    <div class="info-card">
        <div class="info-header">
            <div class="hicon"><i class="fa fa-address-card"></i></div>
            <h6>Profile Information</h6>
        </div>

        <div class="info-row">
            <div class="info-row-icon"><i class="fa fa-envelope"></i></div>
            <div>
                <div class="info-row-label">Email Address</div>
                <div class="info-row-value @(string.IsNullOrEmpty(Model.Email) ? "muted" : "")">
                    @(string.IsNullOrEmpty(Model.Email) ? "Not provided" : Model.Email)
                </div>
            </div>
        </div>

        <div class="info-row">
            <div class="info-row-icon"><i class="fa fa-phone"></i></div>
            <div>
                <div class="info-row-label">Contact Number</div>
                <div class="info-row-value @(string.IsNullOrEmpty(Model.ContactNumber) ? "muted" : "")">
                    @(string.IsNullOrEmpty(Model.ContactNumber) ? "Not provided" : Model.ContactNumber)
                </div>
            </div>
        </div>

        <div class="info-row">
            <div class="info-row-icon"><i class="fa fa-map-marker-alt"></i></div>
            <div>
                <div class="info-row-label">Address</div>
                <div class="info-row-value @(string.IsNullOrEmpty(Model.Address) ? "muted" : "")">
                    @(string.IsNullOrEmpty(Model.Address) ? "Not provided" : Model.Address)
                </div>
            </div>
        </div>

        <div class="info-row">
            <div class="info-row-icon"><i class="fa fa-calendar-alt"></i></div>
            <div>
                <div class="info-row-label">Member Since</div>
                <div class="info-row-value">
                    @(Model.CreatedDate.HasValue ? Model.CreatedDate.Value.ToString("MMMM dd, yyyy") : "—")
                </div>
            </div>
        </div>

        <div class="info-row">
            <div class="info-row-icon"><i class="fa fa-id-badge"></i></div>
            <div>
                <div class="info-row-label">Account Type</div>
                <div class="info-row-value">Employee</div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="action-card">
        <a href="@Url.Action("EditProfile","Employee")" class="btn-edit-p">
            <i class="fa fa-user-pen"></i> Edit Profile
        </a>
        <a href="@Url.Action("Logout","Home")" class="btn-logout-p" id="btnLogout">
            <i class="fa fa-sign-out-alt"></i> Logout
        </a>
    </div>

</div>

@section Scripts {
    <script>
        document.getElementById("btnLogout")?.addEventListener("click", function (e) {
            e.preventDefault();
            var href = this.href;
            Swal.fire({
                title: "Logging out?",
                text: "Are you sure you want to end your session?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#C0392B",
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Yes, logout",
                cancelButtonText: "Cancel"
            }).then(function (result) {
                if (result.isConfirmed) window.location.href = href;
            });
        });
    </script>
}
