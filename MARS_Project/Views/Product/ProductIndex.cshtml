@model IEnumerable<MARS_Project.Models.Product>
@{
    ViewBag.Title = "Products";
    ViewBag.Active = "products";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .pg-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 2px;
    }

    .pg-sub {
        font-size: 12.5px;
        color: #aaa;
        margin-bottom: 18px;
    }

    /* ── Top bar ── */
    .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 18px;
    }

    .btn-add-product {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 20px;
        background: linear-gradient(135deg,#C0392B,#8B1A14);
        color: #fff;
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
        text-decoration: none;
        box-shadow: 0 3px 12px rgba(192,57,43,0.28);
        transition: opacity 0.2s,transform 0.15s;
    }

        .btn-add-product:hover {
            opacity: 0.9;
            color: #fff;
            transform: translateY(-1px);
        }

    /* ── Table card ── */
    .tbl-card {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #eee;
        box-shadow: 0 3px 14px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .tbl-head {
        padding: 13px 20px;
        border-bottom: 1px solid #f0f0f0;
        background: #fafafa;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .tbl-hicon {
        width: 30px;
        height: 30px;
        background: linear-gradient(135deg,#C0392B,#8B1A14);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 12px;
    }

    .tbl-head h6 {
        font-size: 13.5px;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }

    .count-badge {
        background: #fef3f2;
        color: #C0392B;
        border: 1px solid rgba(192,57,43,0.2);
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 12px;
        font-weight: 700;
    }

    .tbl-body {
        padding: 0 20px 16px;
        overflow-x: auto;
    }

    /* ── Table styles ── */
    #tblProducts thead tr {
        background: linear-gradient(135deg,#C0392B,#8B1A14) !important;
        color: #fff !important;
    }

    #tblProducts thead th {
        border: none !important;
        padding: 11px 14px !important;
        font-size: 12px !important;
        font-weight: 600 !important;
        color: #fff !important;
        white-space: nowrap;
    }

    table.dataTable tbody tr {
        border-bottom: 1px solid #f5f5f5;
    }

        table.dataTable tbody tr:hover {
            background: #fefefe !important;
        }

    table.dataTable tbody td {
        padding: 10px 14px !important;
        font-size: 13.5px;
        vertical-align: middle;
        color: #444;
    }

    /* Product image in table */
    .prod-img {
        width: 52px;
        height: 52px;
        border-radius: 10px;
        object-fit: cover;
        border: 1.5px solid #eee;
        display: block;
    }

    /* Product name cell */
    .prod-name {
        font-weight: 600;
        color: #1a1a2e;
        font-size: 13.5px;
    }

    .prod-desc {
        font-size: 12px;
        color: #aaa;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 160px;
        display: block;
    }

    /* Price chip */
    .price-chip {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        background: #fef3f2;
        color: #C0392B;
        border-radius: 8px;
        padding: 3px 9px;
        font-size: 12.5px;
        font-weight: 700;
    }

    /* Stock chip */
    .stock-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 9px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
    }

        .stock-chip.ok {
            background: #e8f8f0;
            color: #1a7a47;
        }

        .stock-chip.low {
            background: #fff8e6;
            color: #b7770d;
        }

        .stock-chip.out {
            background: #fef3f2;
            color: #C0392B;
        }

    /* Category chip */
    .cat-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #eef5ff;
        color: #1a5fa8;
        border-radius: 8px;
        padding: 3px 9px;
        font-size: 12px;
        font-weight: 600;
    }

    /* Action buttons */
    .act-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 1.5px solid #eee;
        background: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.18s;
    }

        .act-btn.edit {
            color: #2980b9;
            border-color: #aecbf5;
        }

            .act-btn.edit:hover {
                background: #2980b9;
                border-color: #2980b9;
                color: #fff;
            }

        .act-btn.del {
            color: #C0392B;
            border-color: rgba(192,57,43,0.25);
        }

            .act-btn.del:hover {
                background: #C0392B;
                border-color: #C0392B;
                color: #fff;
            }
</style>

<div class="pg-title"><i class="fa fa-mobile-alt me-2" style="color:#C0392B;"></i>Products</div>
<div class="pg-sub">Manage all products in the inventory</div>

<!-- Top bar -->
<div class="top-bar">
    <div></div>
    <a href="@Url.Action("ProductCreate","Product")" class="btn-add-product">
        <i class="fa fa-plus"></i> Add New Product
    </a>
</div>

<!-- Table card -->
<div class="tbl-card">
    <div class="tbl-head">
        <div class="tbl-hicon"><i class="fa fa-mobile-alt"></i></div>
        <h6>All Products</h6>
        <span class="count-badge">@Model.Count()</span>
    </div>

    <div class="tbl-body">
        <table id="tblProducts" class="table w-100" style="margin-top:14px;">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Category</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    string stockClass = item.Stock > 10 ? "ok" : item.Stock > 0 ? "low" : "out";
                    string stockLabel = item.Stock > 10 ? "In Stock" : item.Stock > 0 ? "Low Stock" : "Out of Stock";

                    <tr>
                        <td>
                            <img class="prod-img"
                                 src="@Url.Content(string.IsNullOrEmpty(item.ImageURL) ? "~/Content/Images/andoridePhon.jpg" : item.ImageURL)"
                                 alt="@item.Name" />
                        </td>
                        <td>
                            <span class="prod-name">@item.Name</span>
                            <span class="prod-desc" title="@item.Description">@item.Description</span>
                        </td>
                        <td>
                            <span class="price-chip">Rs. @item.Price.ToString("N0")</span>
                        </td>
                        <td>
                            <span class="stock-chip @stockClass">
                                @item.Stock — @stockLabel
                            </span>
                        </td>
                        <td>
                            <span class="cat-chip">
                                <i class="fa fa-list" style="font-size:10px;"></i>
                                @(item.ProductCategory != null ? item.ProductCategory.ProductCategoryName : "No Category")
                            </span>
                        </td>
                        <td>
                            <div style="display:flex;gap:6px;align-items:center;">
                                <a href="@Url.Action("ProductEdit","Product", new { id = item.ProductID })"
                                   class="act-btn edit" title="Edit Product">
                                    <i class="fa fa-pen"></i>
                                </a>
                                <a href="@Url.Action("ProductDelete","Product", new { id = item.ProductID })"
                                   class="act-btn del btn-delete"
                                   title="Delete Product"
                                   data-name="@item.Name">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // ── DataTable init
        $(document).ready(function () {
            $('#tblProducts').DataTable({
                dom: 'Bfrtip',
                buttons: [
                    { extend:'excelHtml5', text:'<i class="fa fa-file-excel"></i> Excel', className:'dt-btn' },
                    { extend:'pdfHtml5',   text:'<i class="fa fa-file-pdf"></i> PDF',     className:'dt-btn', orientation:'landscape' },
                    { extend:'print',      text:'<i class="fa fa-print"></i> Print',      className:'dt-btn' }
                ],
                pageLength: 10,
                language: { search:'Search:', paginate:{ previous:'&lsaquo;', next:'&rsaquo;' } },
                columnDefs: [{ orderable: false, targets: [0, 5] }]
            });
        });

        // ── Delete SweetAlert confirm
        document.querySelectorAll('.btn-delete').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                var url  = this.href;
                var name = this.getAttribute('data-name') || 'this product';
                Swal.fire({
                    title: 'Delete Product?',
                    html: 'Are you sure you want to delete <strong>' + name + '</strong>?<br><small style="color:#aaa;">This action cannot be undone.</small>',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#C0392B',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, Delete It!',
                    cancelButtonText: 'Cancel',
                    reverseButtons: true
                }).then(function(result) {
                    if (result.isConfirmed) {
                        window.location.href = url;
                    }
                });
            });
        });

        // ── TempData messages
        @if (TempData["Message"] != null)
        {
            <text>
            Swal.fire({
                icon: 'success',
                title: 'Done!',
                text: '@TempData["Message"]',
                confirmButtonColor: '#C0392B',
                timer: 2500,
                timerProgressBar: true
            });
            </text>
        }

        @if (TempData["Error"] != null)
        {
            <text>
            Swal.fire({
                icon: 'error',
                title: 'Cannot Delete!',
                text: '@TempData["Error"]',
                confirmButtonColor: '#C0392B'
            });
            </text>
        }
    </script>
    <style>
        .dt-btn {
            background: linear-gradient(135deg,#C0392B,#8B1A14) !important;
            color: #fff !important;
            border: none !important;
            border-radius: 7px !important;
            padding: 5px 12px !important;
            font-size: 12px !important;
            margin-right: 4px !important;
        }

            .dt-btn:hover {
                opacity: 0.85 !important;
            }
    </style>
}
