@model IEnumerable<MARS_Project.Models.ProductCategory>
@{
    ViewBag.Title = "Product Categories";
    ViewBag.Active = "categories";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .pg-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 2px;
    }

    .pg-sub {
        font-size: 12.5px;
        color: #aaa;
        margin-bottom: 18px;
    }

    .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 18px;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 20px;
        background: linear-gradient(135deg,#C0392B,#8B1A14);
        color: #fff;
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
        text-decoration: none;
        border: none;
        cursor: pointer;
        box-shadow: 0 3px 12px rgba(192,57,43,0.28);
        transition: opacity 0.2s,transform 0.15s;
    }

        .btn-add:hover {
            opacity: 0.9;
            color: #fff;
            transform: translateY(-1px);
        }

    /* Table card */
    .tbl-card {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #eee;
        box-shadow: 0 3px 14px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .tbl-head {
        padding: 13px 20px;
        border-bottom: 1px solid #f0f0f0;
        background: #fafafa;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .tbl-hicon {
        width: 30px;
        height: 30px;
        background: linear-gradient(135deg,#C0392B,#8B1A14);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 12px;
    }

    .tbl-head h6 {
        font-size: 13.5px;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }

    .count-badge {
        background: #fef3f2;
        color: #C0392B;
        border: 1px solid rgba(192,57,43,0.2);
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 12px;
        font-weight: 700;
    }

    .tbl-body {
        padding: 0 20px 16px;
        overflow-x: auto;
    }

    #tblCat thead tr {
        background: linear-gradient(135deg,#C0392B,#8B1A14) !important;
        color: #fff !important;
    }

    #tblCat thead th {
        border: none !important;
        padding: 11px 14px !important;
        font-size: 12px !important;
        font-weight: 600 !important;
        color: #fff !important;
    }

    table.dataTable tbody tr {
        border-bottom: 1px solid #f5f5f5;
    }

        table.dataTable tbody tr:hover {
            background: #fefefe !important;
        }

    table.dataTable tbody td {
        padding: 11px 14px !important;
        font-size: 13.5px;
        vertical-align: middle;
        color: #444;
    }

    .cat-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        background: #fef3f2;
        color: #C0392B;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        vertical-align: middle;
        margin-right: 10px;
        flex-shrink: 0;
    }

    .cat-name {
        font-weight: 600;
        color: #1a1a2e;
        vertical-align: middle;
    }

    .row-num {
        width: 26px;
        height: 26px;
        border-radius: 7px;
        background: #f5f5f5;
        color: #aaa;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11.5px;
        font-weight: 700;
    }

    .act-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 1.5px solid #eee;
        background: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.18s;
    }

        .act-btn.edit {
            color: #2980b9;
            border-color: #aecbf5;
        }

            .act-btn.edit:hover {
                background: #2980b9;
                border-color: #2980b9;
                color: #fff;
            }

        .act-btn.del {
            color: #C0392B;
            border-color: rgba(192,57,43,0.25);
        }

            .act-btn.del:hover {
                background: #C0392B;
                border-color: #C0392B;
                color: #fff;
            }

    /* ══ SIDE MODAL (drawer) ══ */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.35);
        z-index: 900;
        display: none;
        backdrop-filter: blur(3px);
    }

        .modal-overlay.open {
            display: block;
        }

    .side-modal {
        position: fixed;
        top: 0;
        right: -420px;
        width: 380px;
        max-width: 95vw;
        height: 100vh;
        background: #fff;
        z-index: 901;
        display: flex;
        flex-direction: column;
        box-shadow: -8px 0 32px rgba(0,0,0,0.12);
        transition: right 0.3s cubic-bezier(0.22,1,0.36,1);
    }

        .side-modal.open {
            right: 0;
        }

    /* Modal header */
    .sm-head {
        padding: 18px 22px;
        background: linear-gradient(135deg,#1a0a08,#C0392B);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
        position: relative;
        overflow: hidden;
    }

        .sm-head::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.05) 1px,transparent 1px);
            background-size: 24px 24px;
        }

    .sm-head-text {
        position: relative;
        z-index: 2;
    }

        .sm-head-text h5 {
            font-size: 15px;
            font-weight: 700;
            color: #fff;
            margin: 0 0 2px;
        }

        .sm-head-text small {
            font-size: 11.5px;
            color: rgba(255,255,255,0.6);
        }

    .sm-close {
        position: relative;
        z-index: 2;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255,255,255,0.15);
        border: none;
        color: #fff;
        font-size: 15px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.18s;
    }

        .sm-close:hover {
            background: rgba(255,255,255,0.28);
        }

    /* Modal body */
    .sm-body {
        flex: 1;
        padding: 24px 22px;
        overflow-y: auto;
    }

    .field {
        margin-bottom: 20px;
    }

        .field label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.7px;
            margin-bottom: 7px;
        }

    .fw {
        position: relative;
    }

        .fw .fi {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #C0392B;
            font-size: 13px;
            pointer-events: none;
        }

        .fw input {
            width: 100%;
            padding: 11px 13px 11px 37px;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            font-size: 13.5px;
            color: #1a1a2e;
            background: #fdfdfd;
            outline: none;
            font-family: 'DM Sans',sans-serif;
            transition: border-color 0.2s,box-shadow 0.2s;
        }

            .fw input:focus {
                border-color: #C0392B;
                box-shadow: 0 0 0 3px rgba(192,57,43,0.1);
                background: #fff;
            }

    /* Edit info row */
    .edit-info {
        background: #f5f5f5;
        border-radius: 10px;
        padding: 10px 14px;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12.5px;
        color: #666;
    }

        .edit-info i {
            color: #C0392B;
            font-size: 12px;
        }

        .edit-info strong {
            color: #1a1a2e;
        }

    /* Modal footer */
    .sm-foot {
        padding: 16px 22px;
        border-top: 1px solid #f0f0f0;
        background: #fafafa;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-shrink: 0;
    }

    .btn-modal-save {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 24px;
        background: linear-gradient(135deg,#C0392B,#8B1A14);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 14px rgba(192,57,43,0.25);
        transition: opacity 0.2s,transform 0.15s;
    }

        .btn-modal-save:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

    .btn-modal-cancel {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 18px;
        background: transparent;
        color: #555;
        border: 1.5px solid #e0e0e0;
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
        transition: border-color 0.2s,color 0.2s;
    }

        .btn-modal-cancel:hover {
            border-color: #C0392B;
            color: #C0392B;
        }
</style>

<div class="pg-title"><i class="fa fa-list me-2" style="color:#C0392B;"></i>Product Categories</div>
<div class="pg-sub">Manage all product categories</div>

<div class="top-bar">
    <div></div>
    <button class="btn-add" onclick="openAddModal()">
        <i class="fa fa-plus"></i> Add Category
    </button>
</div>

<!-- Table -->
<div class="tbl-card">
    <div class="tbl-head">
        <div class="tbl-hicon"><i class="fa fa-list"></i></div>
        <h6>All Categories</h6>
        <span class="count-badge">@Model.Count()</span>
    </div>
    <div class="tbl-body">
        <table id="tblCat" class="table w-100" style="margin-top:14px;">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Category Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int cnt = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="row-num">@cnt</span></td>
                        <td>
                            <span class="cat-icon"><i class="fa fa-list"></i></span>
                            <span class="cat-name">@item.ProductCategoryName</span>
                        </td>
                        <td>
                            <div style="display:flex;gap:6px;">
                                <button type="button"
                                        class="act-btn edit"
                                        title="Edit"
                                        onclick="openEditModal(@item.ProductCategoryID, '@Html.Raw(item.ProductCategoryName.Replace("'", "\\'"))')">
                                    <i class="fa fa-pen"></i>
                                </button>
                                <button type="button"
                                        class="act-btn del"
                                        title="Delete"
                                        onclick="confirmDelete(@item.ProductCategoryID, '@Html.Raw(item.ProductCategoryName.Replace("'", "\\'"))')">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    cnt++;
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ══ SIDE MODAL ══ -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModal()"></div>

<div class="side-modal" id="sideModal">
    <div class="sm-head">
        <div class="sm-head-text">
            <h5 id="modalTitle">Add Category</h5>
            <small id="modalSubtitle">Fill in the details below</small>
        </div>
        <button class="sm-close" onclick="closeModal()"><i class="fa fa-xmark"></i></button>
    </div>

    <div class="sm-body">
        <!-- Edit info (shown only in edit mode) -->
        <div class="edit-info" id="editInfoRow" style="display:none;">
            <i class="fa fa-tag"></i>
            Editing: <strong id="editInfoName"></strong>
        </div>

        <div class="field">
            <label>Category Name</label>
            <div class="fw">
                <i class="fi fa fa-list"></i>
                <input type="text" id="catNameInput" placeholder="e.g. Smartphones, Accessories..." />
            </div>
            <span id="catNameError" style="font-size:11.5px;color:#C0392B;display:none;margin-top:4px;">
                <i class="fa fa-circle-exclamation"></i> Category name is required.
            </span>
        </div>
    </div>

    <div class="sm-foot">
        <button class="btn-modal-cancel" onclick="closeModal()">
            <i class="fa fa-times"></i> Cancel
        </button>
        <button class="btn-modal-save" id="modalSaveBtn" onclick="saveCategory()">
            <i class="fa fa-plus"></i> <span id="modalSaveBtnText">Add Category</span>
        </button>
    </div>
</div>

<!-- Hidden forms -->
@using (Html.BeginForm("Create", "ProductCategories", FormMethod.Post, new { id = "formCreate" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="ProductCategoryName" id="hiddenCreateName" />
}

@using (Html.BeginForm("Edit", "ProductCategories", FormMethod.Post, new { id = "formEdit" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="ProductCategoryID" id="hiddenEditId" />
    <input type="hidden" name="ProductCategoryName" id="hiddenEditName" />
}

@using (Html.BeginForm("Delete", "ProductCategories", FormMethod.Get, new { id = "formDelete" }))
{
    <input type="hidden" name="id" id="hiddenDeleteId" />
}

@section Scripts {
    <script>
        // ── DataTable
        $(document).ready(function () {
            $('#tblCat').DataTable({
                dom: 'Bfrtip',
                buttons: [
                    { extend:'excelHtml5', text:'<i class="fa fa-file-excel"></i> Excel', className:'dt-btn' },
                    { extend:'print',      text:'<i class="fa fa-print"></i> Print',      className:'dt-btn' }
                ],
                pageLength: 10,
                language: { search:'Search:', paginate:{ previous:'&lsaquo;', next:'&rsaquo;' } },
                columnDefs: [{ orderable:false, targets:[2] }]
            });
        });

        // ── Modal state
        var modalMode = 'add'; // 'add' or 'edit'
        var editId    = null;

        function openAddModal() {
            modalMode = 'add';
            document.getElementById('modalTitle').textContent    = 'Add Category';
            document.getElementById('modalSubtitle').textContent = 'Create a new product category';
            document.getElementById('editInfoRow').style.display = 'none';
            document.getElementById('catNameInput').value        = '';
            document.getElementById('catNameError').style.display = 'none';
            document.getElementById('modalSaveBtnText').textContent = 'Add Category';
            document.getElementById('modalSaveBtn').querySelector('i').className = 'fa fa-plus';
            openModal();
            setTimeout(function() { document.getElementById('catNameInput').focus(); }, 320);
        }

        function openEditModal(id, name) {
            modalMode = 'edit';
            editId    = id;
            document.getElementById('modalTitle').textContent    = 'Edit Category';
            document.getElementById('modalSubtitle').textContent = 'Update the category name';
            document.getElementById('editInfoRow').style.display = 'flex';
            document.getElementById('editInfoName').textContent  = name;
            document.getElementById('catNameInput').value        = name;
            document.getElementById('catNameError').style.display = 'none';
            document.getElementById('modalSaveBtnText').textContent = 'Save Changes';
            document.getElementById('modalSaveBtn').querySelector('i').className = 'fa fa-save';
            openModal();
            setTimeout(function() {
                var inp = document.getElementById('catNameInput');
                inp.focus();
                inp.select();
            }, 320);
        }

        function openModal() {
            document.getElementById('modalOverlay').classList.add('open');
            document.getElementById('sideModal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            document.getElementById('modalOverlay').classList.remove('open');
            document.getElementById('sideModal').classList.remove('open');
            document.body.style.overflow = '';
        }

        // Close on Escape
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeModal();
        });

        function saveCategory() {
            var name = document.getElementById('catNameInput').value.trim();
            if (!name) {
                document.getElementById('catNameError').style.display = 'block';
                document.getElementById('catNameInput').focus();
                return;
            }
            document.getElementById('catNameError').style.display = 'none';

            if (modalMode === 'add') {
                document.getElementById('hiddenCreateName').value = name;
                document.getElementById('formCreate').submit();
            } else {
                document.getElementById('hiddenEditId').value   = editId;
                document.getElementById('hiddenEditName').value = name;
                document.getElementById('formEdit').submit();
            }
        }

        // ── Delete confirm
        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Delete Category?',
                html: 'Are you sure you want to delete <strong>' + name + '</strong>?<br><small style="color:#aaa;">Products in this category will become uncategorized.</small>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#C0392B',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Delete!',
                cancelButtonText: 'Cancel',
                reverseButtons: true
            }).then(function(r) {
                if (r.isConfirmed) {
                    document.getElementById('hiddenDeleteId').value = id;
                    document.getElementById('formDelete').submit();
                }
            });
        }

        // ── TempData messages
        @if (TempData["Message"] != null) {
            <text>
            Swal.fire({ icon:'success', title:'Done!', text:'@TempData["Message"]', confirmButtonColor:'#C0392B', timer:2500, timerProgressBar:true });
            </text>
        }
        @if (TempData["Error"] != null) {
            <text>
            Swal.fire({ icon:'error', title:'Error!', text:'@TempData["Error"]', confirmButtonColor:'#C0392B' });
            </text>
        }
    </script>
    <style>
        .dt-btn {
            background: linear-gradient(135deg,#C0392B,#8B1A14) !important;
            color: #fff !important;
            border: none !important;
            border-radius: 7px !important;
            padding: 5px 12px !important;
            font-size: 12px !important;
            margin-right: 4px !important;
        }

            .dt-btn:hover {
                opacity: 0.85 !important;
            }
    </style>
}
