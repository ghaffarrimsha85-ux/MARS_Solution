@model MARS_Project.Models.User
@{
    ViewBag.Title = "Edit Employee";
    ViewBag.Active = "employees";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .pg-title { font-size:1.15rem; font-weight:700; color:#1a1a2e; margin-bottom:2px; }
    .pg-sub   { font-size:12.5px; color:#aaa; margin-bottom:20px; }
    .form-wrapper { max-width:520px; }

    .f-card { background:#fff; border-radius:14px; border:1px solid #eee; box-shadow:0 3px 14px rgba(0,0,0,0.05); overflow:hidden; margin-bottom:14px; }
    .f-head { padding:13px 20px; border-bottom:1px solid #f0f0f0; background:#fafafa; display:flex; align-items:center; gap:10px; }
    .f-head .fhi { width:30px; height:30px; background:linear-gradient(135deg,#C0392B,#8B1A14); border-radius:8px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:12px; }
    .f-head h6 { font-size:13.5px; font-weight:700; color:#1a1a2e; margin:0; }
    .f-body { padding:20px 22px; }

    /* Employee info bar */
    .emp-info-bar {
        background:#f8f8f8; border-radius:10px;
        padding:12px 15px; margin-bottom:18px;
        display:flex; align-items:center; gap:12px;
        border:1px solid #eee;
    }
    .emp-avatar {
        width:44px; height:44px; border-radius:50%;
        background:linear-gradient(135deg,#1a5fa8,#3498db);
        display:flex; align-items:center; justify-content:center;
        color:#fff; font-size:17px; font-weight:700; flex-shrink:0;
    }
    .emp-info-bar .e-name { font-size:14px; font-weight:700; color:#1a1a2e; }
    .emp-info-bar .e-id   { font-size:11.5px; color:#aaa; }

    /* Status badge */
    .status-badge-bar {
        display:inline-flex; align-items:center; gap:5px;
        padding:3px 10px; border-radius:20px;
        font-size:11.5px; font-weight:700;
    }
    .status-badge-bar.active   { background:#e8f8f0; color:#1a7a47; border:1px solid #b7e4cc; }
    .status-badge-bar.inactive { background:#fef3f2; color:#C0392B; border:1px solid rgba(192,57,43,0.25); }
    .status-dot-s { width:6px; height:6px; border-radius:50%; background:currentColor; }

    /* Fields */
    .fields-grid { display:grid; grid-template-columns:1fr 1fr; gap:0 18px; }
    .field { margin-bottom:18px; }
    .field.full { grid-column:1/-1; }
    .field label { display:block; font-size:11px; font-weight:600; color:#888; text-transform:uppercase; letter-spacing:0.7px; margin-bottom:6px; }
    .fw { position:relative; }
    .fw .fi { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#C0392B; font-size:13px; pointer-events:none; }
    .fw input, .fw select {
        width:100%; padding:10px 13px 10px 37px;
        border:1.5px solid #e5e7eb; border-radius:10px;
        font-size:13.5px; color:#1a1a2e;
        background:#fdfdfd; outline:none;
        font-family:'DM Sans',sans-serif;
        transition:border-color 0.2s,box-shadow 0.2s;
        appearance:none;
    }
    .fw input:focus, .fw select:focus { border-color:#C0392B; box-shadow:0 0 0 3px rgba(192,57,43,0.1); background:#fff; }
    .fw input[readonly] { background:#f5f5f5; color:#aaa; cursor:not-allowed; }
    .readonly-hint { font-size:10.5px; color:#bbb; margin-top:3px; display:flex; align-items:center; gap:4px; }

    /* Action bar */
    .action-bar { background:#fff; border-radius:14px; border:1px solid #eee; box-shadow:0 3px 14px rgba(0,0,0,0.05); padding:16px 20px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
    .btn-save { display:inline-flex; align-items:center; gap:7px; padding:10px 24px; background:linear-gradient(135deg,#C0392B,#8B1A14); color:#fff; border:none; border-radius:11px; font-size:14px; font-weight:700; cursor:pointer; box-shadow:0 4px 14px rgba(192,57,43,0.28); transition:opacity 0.2s,transform 0.15s; }
    .btn-save:hover { opacity:0.9; transform:translateY(-1px); }
    .btn-back { display:inline-flex; align-items:center; gap:6px; padding:9px 18px; background:transparent; color:#555; border:1.5px solid #e0e0e0; border-radius:11px; font-size:13.5px; font-weight:600; text-decoration:none; transition:border-color 0.2s,color 0.2s; }
    .btn-back:hover { border-color:#C0392B; color:#C0392B; }

    @@media(max-width:540px) {
        .fields-grid { grid-template-columns:1fr; }
        .field.full { grid-column:auto; }
        .f-body { padding:16px; }
        .action-bar { flex-direction:column; }
        .btn-save, .btn-back { width:100%; justify-content:center; }
    }
</style>

<div class="pg-title"><i class="fa fa-user-pen me-2" style="color:#C0392B;"></i>Edit Employee</div>
<div class="pg-sub">Update employee account information</div>

<div class="form-wrapper">
    @using (Html.BeginForm("EditEmployee", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.UserID)

        <!-- Employee info bar -->
        <div class="emp-info-bar">
            <div class="emp-avatar">
                @(Model.Name != null && Model.Name.Length > 0 ? Model.Name[0].ToString().ToUpper() : "E")
            </div>
            <div style="flex:1;">
                <div class="e-name">@Model.Name</div>
                <div class="e-id">Employee ID: #@Model.UserID</div>
            </div>
            @{
                bool isActive = Model.Status == "Active" || Model.Status == "Approved";
                string stClass = isActive ? "active" : "inactive";
                string stLabel = isActive ? "Active" : "Inactive";
            }
            <span class="status-badge-bar @stClass">
                <span class="status-dot-s"></span> @stLabel
            </span>
        </div>

        <!-- Personal Info -->
        <div class="f-card">
            <div class="f-head">
                <div class="fhi"><i class="fa fa-user-tie"></i></div>
                <h6>Personal Information</h6>
            </div>
            <div class="f-body">
                <div class="fields-grid">

                    <div class="field full">
                        <label>Full Name</label>
                        <div class="fw">
                            <i class="fi fa fa-user"></i>
                            @Html.TextBoxFor(m => m.Name, new { placeholder = "Full name", autocomplete = "off" })
                        </div>
                    </div>

                    <div class="field full">
                        <label>Email Address</label>
                        <div class="fw">
                            <i class="fi fa fa-envelope"></i>
                            @Html.TextBoxFor(m => m.Email, new { placeholder = "Email", @readonly = "readonly" })
                        </div>
                        <div class="readonly-hint"><i class="fa fa-lock" style="font-size:10px;color:#C0392B;"></i> Email cannot be changed</div>
                    </div>

                    <div class="field">
                        <label>Contact Number</label>
                        <div class="fw">
                            <i class="fi fa fa-phone"></i>
                            @Html.TextBoxFor(m => m.ContactNumber, new { placeholder = "03xx-xxxxxxx" })
                        </div>
                    </div>

                    <div class="field">
                        <label>Address</label>
                        <div class="fw">
                            <i class="fi fa fa-map-marker-alt"></i>
                            @Html.TextBoxFor(m => m.Address, new { placeholder = "Employee address" })
                        </div>
                    </div>

                    <div class="field full">
                        <label>Account Status</label>
                        <div class="fw">
                            <i class="fi fa fa-circle-check"></i>
                            @Html.DropDownListFor(m => m.Status,
                                     new SelectList(new[] { "Active", "Inactive" }, Model.Status),
                                     "-- Select Status --")
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="action-bar">
            <a href="@Url.Action("ManageEmployees","Admin")" class="btn-back">
                <i class="fa fa-arrow-left"></i> Back to Employees
            </a>
            <button type="submit" class="btn-save">
                <i class="fa fa-save"></i> Save Changes
            </button>
        </div>
    }
</div>

@section Scripts {
    @if (TempData["Message"] != null)
    {
        <script>
            Swal.fire({ icon:'success', title:'Updated!', text:'@TempData["Message"]', confirmButtonColor:'#C0392B', timer:2500 });
        </script>
    }
}
