@model MARS_Project.Models.RepairRequest
@{
    ViewBag.Title = "Assign Repair";
    ViewBag.Active = "repairs";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .pg-title { font-size:1.15rem; font-weight:700; color:#1a1a2e; margin-bottom:2px; }
    .pg-sub   { font-size:12.5px; color:#aaa; margin-bottom:20px; }
    .form-wrapper { max-width:620px; }

    /* Request info card */
    .req-info-card {
        background:#fff; border-radius:14px; border:1px solid #eee;
        box-shadow:0 3px 14px rgba(0,0,0,0.05); overflow:hidden; margin-bottom:14px;
    }
    .req-info-header {
        background:linear-gradient(135deg,#1a0a08,#C0392B);
        padding:16px 22px; position:relative; overflow:hidden;
    }
    .req-info-header::before {
        content:''; position:absolute; inset:0;
        background-image:linear-gradient(rgba(255,255,255,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.04) 1px,transparent 1px);
        background-size:24px 24px;
    }
    .req-info-header h6 { position:relative; z-index:2; font-size:14px; font-weight:700; color:#fff; margin:0; display:flex; align-items:center; gap:8px; }

    .req-info-body { padding:18px 22px; }
    .req-info-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:14px; }
    .info-box { background:#f8f8f8; border-radius:10px; padding:11px 14px; border:1px solid #f0f0f0; }
    .info-box .ib-label { font-size:10.5px; font-weight:600; color:#aaa; text-transform:uppercase; letter-spacing:0.7px; margin-bottom:3px; }
    .info-box .ib-value { font-size:13.5px; font-weight:600; color:#1a1a2e; }

    /* Status pill */
    .sp { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11.5px; font-weight:700; }
    .sp-dot { width:6px; height:6px; border-radius:50%; background:currentColor; }
    .sp.pending  { background:#fff8e6; color:#b7770d; border:1px solid #f5d87a; }
    .sp.assigned { background:#eef5ff; color:#1a5fa8; border:1px solid #aecbf5; }

    /* Description box */
    .desc-box { background:#fef3f2; border-radius:10px; padding:13px 15px; border:1px solid rgba(192,57,43,0.15); margin-bottom:14px; }
    .desc-box .db-label { font-size:10.5px; font-weight:600; color:#C0392B; text-transform:uppercase; letter-spacing:0.7px; margin-bottom:5px; }
    .desc-box .db-text  { font-size:13.5px; color:#444; line-height:1.6; }

    /* Images row */
    .imgs-label { font-size:11px; font-weight:600; color:#aaa; text-transform:uppercase; letter-spacing:0.7px; margin-bottom:8px; }
    .imgs-row { display:flex; gap:10px; }
    .img-thumb { width:70px; height:70px; border-radius:10px; overflow:hidden; border:1.5px solid #eee; }
    .img-thumb img { width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.2s; }
    .img-thumb:hover img { transform:scale(1.08); }
    .img-empty { width:70px; height:70px; border-radius:10px; background:#f5f5f5; border:1.5px dashed #ddd; display:flex; align-items:center; justify-content:center; color:#ccc; font-size:18px; }

    /* Assign form card */
    .f-card { background:#fff; border-radius:14px; border:1px solid #eee; box-shadow:0 3px 14px rgba(0,0,0,0.05); overflow:hidden; margin-bottom:14px; }
    .f-head { padding:13px 20px; border-bottom:1px solid #f0f0f0; background:#fafafa; display:flex; align-items:center; gap:10px; }
    .f-head .fhi { width:30px; height:30px; background:linear-gradient(135deg,#C0392B,#8B1A14); border-radius:8px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:12px; }
    .f-head h6 { font-size:13.5px; font-weight:700; color:#1a1a2e; margin:0; }
    .f-body { padding:20px 22px; }

    .field { margin-bottom:0; }
    .field label { display:block; font-size:11px; font-weight:600; color:#888; text-transform:uppercase; letter-spacing:0.7px; margin-bottom:7px; }
    .fw { position:relative; }
    .fw .fi { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#C0392B; font-size:13px; pointer-events:none; }
    .fw select {
        width:100%; padding:11px 13px 11px 37px;
        border:1.5px solid #e5e7eb; border-radius:10px;
        font-size:13.5px; color:#1a1a2e;
        background:#fdfdfd; outline:none;
        font-family:'DM Sans',sans-serif;
        appearance:none;
        transition:border-color 0.2s,box-shadow 0.2s;
    }
    .fw select:focus { border-color:#C0392B; box-shadow:0 0 0 3px rgba(192,57,43,0.1); background:#fff; }

    /* Already assigned note */
    .assigned-note {
        display:flex; align-items:center; gap:8px;
        background:#eef5ff; border:1px solid #aecbf5;
        border-radius:10px; padding:10px 14px;
        font-size:12.5px; color:#1a5fa8;
        margin-top:10px;
    }
    .assigned-note i { font-size:13px; flex-shrink:0; }

    /* Action bar */
    .action-bar { background:#fff; border-radius:14px; border:1px solid #eee; box-shadow:0 3px 14px rgba(0,0,0,0.05); padding:16px 20px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
    .btn-save { display:inline-flex; align-items:center; gap:7px; padding:10px 26px; background:linear-gradient(135deg,#C0392B,#8B1A14); color:#fff; border:none; border-radius:11px; font-size:14px; font-weight:700; cursor:pointer; box-shadow:0 4px 14px rgba(192,57,43,0.28); transition:opacity 0.2s,transform 0.15s; }
    .btn-save:hover { opacity:0.9; transform:translateY(-1px); }
    .btn-back { display:inline-flex; align-items:center; gap:6px; padding:9px 18px; background:transparent; color:#555; border:1.5px solid #e0e0e0; border-radius:11px; font-size:13.5px; font-weight:600; text-decoration:none; transition:border-color 0.2s,color 0.2s; }
    .btn-back:hover { border-color:#C0392B; color:#C0392B; }

    @@media(max-width:540px) {
        .req-info-grid { grid-template-columns:1fr; }
        .action-bar { flex-direction:column; }
        .btn-save, .btn-back { width:100%; justify-content:center; }
    }
</style>

<div class="pg-title"><i class="fa fa-user-plus me-2" style="color:#C0392B;"></i>Assign Repair Request</div>
<div class="pg-sub">Select an employee to handle this repair request</div>

<div class="form-wrapper">

    <!-- Request Info Card -->
    <div class="req-info-card">
        <div class="req-info-header">
            <h6>
                <i class="fa fa-wrench"></i>
                Repair Request #@Model.RequestID
            </h6>
        </div>
        <div class="req-info-body">

            <!-- Info grid -->
            <div class="req-info-grid">
                <div class="info-box">
                    <div class="ib-label">Customer</div>
                    <div class="ib-value">
                        @(Model.User != null ? Model.User.Name : "Unknown")
                    </div>
                </div>
                <div class="info-box">
                    <div class="ib-label">Request Date</div>
                    <div class="ib-value">
                        @(Model.RequestDate.HasValue ? Model.RequestDate.Value.ToString("MMM dd, yyyy") : "—")
                    </div>
                </div>
                <div class="info-box">
                    <div class="ib-label">Current Status</div>
                    <div class="ib-value">
                        @{
                            string sc = Model.Status == "Pending" ? "pending" : "assigned";
                        }
                        <span class="sp @sc">
                            <span class="sp-dot"></span> @Model.Status
                        </span>
                    </div>
                </div>
                <div class="info-box">
                    <div class="ib-label">Currently Assigned</div>
                    <div class="ib-value">
                        @if (Model.User1 != null)
                        {
                            <span style="color:#1a5fa8;font-weight:700;">
                                <i class="fa fa-user-tie" style="font-size:11px;margin-right:4px;"></i>
                                @Model.User1.Name
                            </span>
                        }
                        else
                        {
                            <span style="color:#bbb;font-style:italic;font-size:13px;">Not assigned yet</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="desc-box">
                <div class="db-label"><i class="fa fa-comment-dots" style="margin-right:4px;"></i>Problem Description</div>
                <div class="db-text">@Model.ProblemDescription</div>
            </div>

            <!-- Images -->
            <div class="imgs-label">Problem Photos</div>
            <div class="imgs-row">
                @if (!string.IsNullOrEmpty(Model.ProblemImage1))
                {
                    <a href="@Model.ProblemImage1" target="_blank" class="img-thumb" title="Photo 1">
                        <img src="@Model.ProblemImage1" alt="img1" />
                    </a>
                }
                else
                { <div class="img-empty"><i class="fa fa-image"></i></div>}

                @if (!string.IsNullOrEmpty(Model.ProblemImage2))
                {
                    <a href="@Model.ProblemImage2" target="_blank" class="img-thumb" title="Photo 2">
                        <img src="@Model.ProblemImage2" alt="img2" />
                    </a>
                }
                else
                { <div class="img-empty"><i class="fa fa-image"></i></div>}

                @if (!string.IsNullOrEmpty(Model.ProblemImage3))
                {
                    <a href="@Model.ProblemImage3" target="_blank" class="img-thumb" title="Photo 3">
                        <img src="@Model.ProblemImage3" alt="img3" />
                    </a>
                }
                else
                { <div class="img-empty"><i class="fa fa-image"></i></div>}
            </div>

        </div>
    </div>

    <!-- Assign Form -->
    @using (Html.BeginForm("AssignRepair", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <input type="hidden" name="RequestID" value="@Model.RequestID" />

        <div class="f-card">
            <div class="f-head">
                <div class="fhi"><i class="fa fa-user-tie"></i></div>
                <h6>Select Employee</h6>
            </div>
            <div class="f-body">
                <div class="field">
                    <label>Assign To Employee</label>
                    <div class="fw">
                        <i class="fi fa fa-user-tie"></i>
                        @Html.DropDownList("AssignedEmployeeID",
                                 (SelectList)ViewBag.Employees,
                                 "-- Select an Employee --",
                                 new { @class = "form-control" })
                    </div>
                </div>

                @if (Model.User1 != null)
                {
                    <div class="assigned-note">
                        <i class="fa fa-circle-info"></i>
                        Currently assigned to <strong>@Model.User1.Name</strong> — selecting a new employee will reassign this request.
                    </div>
                }
            </div>
        </div>

        <div class="action-bar">
            <a href="@Url.Action("RepairRequests","Admin")" class="btn-back">
                <i class="fa fa-arrow-left"></i> Back to Requests
            </a>
            <button type="submit" class="btn-save">
                <i class="fa fa-user-plus"></i> Assign Employee
            </button>
        </div>
    }

</div>
