@model IEnumerable<MARS_Project.Models.User>
@{
    ViewBag.Title = "Manage Customers";
    ViewBag.Active = "customers";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .pg-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 2px;
    }

    .pg-sub {
        font-size: 12.5px;
        color: #aaa;
        margin-bottom: 18px;
    }

    .tbl-card {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #eee;
        box-shadow: 0 3px 14px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .tbl-head {
        padding: 13px 20px;
        border-bottom: 1px solid #f0f0f0;
        background: #fafafa;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .tbl-head-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .tbl-hicon {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg,#C0392B,#8B1A14);
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 13px;
    }

    .tbl-head h6 {
        font-size: 13.5px;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }

    .count-badge {
        background: #e8f8f0;
        color: #1a7a47;
        border: 1px solid #b7e4cc;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 12px;
        font-weight: 700;
    }

    .tbl-body {
        padding: 0 20px 16px;
        overflow-x: auto;
    }

    #tblCustomers thead tr {
        background: linear-gradient(135deg,#C0392B,#8B1A14) !important;
        color: #fff !important;
    }

    #tblCustomers thead th {
        border: none !important;
        padding: 11px 14px !important;
        font-size: 12px !important;
        font-weight: 600 !important;
        color: #fff !important;
    }

    table.dataTable tbody tr {
        border-bottom: 1px solid #f5f5f5;
    }

        table.dataTable tbody tr:hover {
            background: #fefefe !important;
        }

    table.dataTable tbody td {
        padding: 11px 14px !important;
        font-size: 13.5px;
        vertical-align: middle;
        color: #444;
    }

    .u-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg,#1a7a47,#27ae60);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        vertical-align: middle;
        margin-right: 8px;
        flex-shrink: 0;
    }

    .u-name {
        font-weight: 600;
        color: #1a1a2e;
    }

    .sp {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 700;
    }

    .sp-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    .sp.active,
    .sp.approved {
        background: #e8f8f0;
        color: #1a7a47;
        border: 1px solid #b7e4cc;
    }

    .sp.pending {
        background: #fff8e6;
        color: #b7770d;
        border: 1px solid #f5d87a;
    }

    .sp.rejected {
        background: #fef3f2;
        color: #C0392B;
        border: 1px solid rgba(192,57,43,0.25);
    }

    .sp.other {
        background: #f4f4f4;
        color: #888;
        border: 1px solid #ddd;
    }

    .address-cell {
        max-width: 140px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 12.5px;
        color: #888;
    }

    .act-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 1.5px solid #eee;
        background: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.18s;
    }

        .act-btn.edit {
            color: #2980b9;
            border-color: #aecbf5;
        }

            .act-btn.edit:hover {
                background: #2980b9;
                border-color: #2980b9;
                color: #fff;
            }

        .act-btn.del {
            color: #C0392B;
            border-color: rgba(192,57,43,0.25);
        }

            .act-btn.del:hover {
                background: #C0392B;
                border-color: #C0392B;
                color: #fff;
            }
</style>

<div class="pg-title"><i class="fa fa-users me-2" style="color:#C0392B;"></i>Manage Customers</div>
<div class="pg-sub">All registered customers in the system</div>

<div class="tbl-card">
    <div class="tbl-head">
        <div class="tbl-head-left">
            <div class="tbl-hicon"><i class="fa fa-user"></i></div>
            <h6>Customers List</h6>
            <span class="count-badge">@Model.Count()</span>
        </div>
    </div>

    <div class="tbl-body">
        <table id="tblCustomers" class="table w-100" style="margin-top:14px;">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Email</th>
                    <th>Contact</th>
                    <th>Address</th>
                    <th>Joined</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int cnt = 1; }
                @foreach (var cust in Model)
                {
                    string initials = cust.Name != null && cust.Name.Length > 0 ? cust.Name[0].ToString().ToUpper() : "C";
                    string stClass = cust.Status == "Approved" || cust.Status == "Active" ? "approved"
                                    : cust.Status == "Pending" ? "pending"
                                    : cust.Status == "Rejected" ? "rejected" : "other";
                    <tr>
                        <td style="color:#aaa;font-size:12px;">@cnt</td>
                        <td>
                            <span class="u-avatar">@initials</span>
                            <span class="u-name">@cust.Name</span>
                        </td>
                        <td style="font-size:13px;color:#666;">@cust.Email</td>
                        <td style="font-size:13px;">@(string.IsNullOrEmpty(cust.ContactNumber) ? "—" : cust.ContactNumber)</td>
                        <td>
                            <span class="address-cell" title="@cust.Address">
                                @(string.IsNullOrEmpty(cust.Address) ? "—" : cust.Address)
                            </span>
                        </td>
                        <td style="font-size:12px;color:#aaa;">
                            @(cust.CreatedDate.HasValue ? cust.CreatedDate.Value.ToString("MMM dd, yyyy") : "—")
                        </td>
                        <td>
                            <span class="sp @stClass"><span class="sp-dot"></span>@cust.Status</span>
                        </td>
                        <td>
                            <div style="display:flex;gap:5px;">
                                <a href="@Url.Action("EditUser","Admin", new { id = cust.UserID })" class="act-btn edit" title="Edit">
                                    <i class="fa fa-pen"></i>
                                </a>
                                <a href="@Url.Action("DeleteUser","Admin", new { id = cust.UserID })" class="act-btn del btn-delete" title="Delete">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    cnt++;
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tblCustomers').DataTable({
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'excelHtml5', text: '<i class="fa fa-file-excel"></i> Excel', className: 'dt-btn' },
                    { extend: 'pdfHtml5', text: '<i class="fa fa-file-pdf"></i> PDF', className: 'dt-btn' },
                    { extend: 'print', text: '<i class="fa fa-print"></i> Print', className: 'dt-btn' }
                ],
                pageLength: 10,
                language: { search: 'Search:', paginate: { previous: '&lsaquo;', next: '&rsaquo;' } }
            });
        });

        document.querySelectorAll('.btn-delete').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                var url = this.href;
                Swal.fire({
                    title: 'Delete this customer?',
                    text: 'This action cannot be undone!',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#C0392B',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete!'
                }).then(function (r) { if (r.isConfirmed) window.location.href = url; });
            });
        });
    </script>
    <style>
        .dt-btn {
            background: linear-gradient(135deg,#C0392B,#8B1A14) !important;
            color: #fff !important;
            border: none !important;
            border-radius: 7px !important;
            padding: 5px 12px !important;
            font-size: 12px !important;
            margin-right: 4px !important;
        }

            .dt-btn:hover {
                opacity: 0.85 !important;
            }
    </style>
}
