@model MARS_Project.Models.Order
@{
    Layout = null;
}

<style>
    .modal-header-custom {
        background: linear-gradient(135deg, #1a0a08, #C0392B);
        padding: 16px 22px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }

        .modal-header-custom::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.04) 1px,transparent 1px);
            background-size: 24px 24px;
        }

        .modal-header-custom h5 {
            position: relative;
            z-index: 2;
            font-size: 15px;
            font-weight: 700;
            color: #fff;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

    .modal-close-btn {
        position: relative;
        z-index: 2;
        width: 30px;
        height: 30px;
        background: rgba(255,255,255,0.15);
        border: none;
        border-radius: 50%;
        color: #fff;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.18s;
    }

        .modal-close-btn:hover {
            background: rgba(255,255,255,0.28);
        }

    .modal-body-custom {
        padding: 22px;
        background: #fff;
    }

    /* Info strip */
    .order-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 18px;
    }

    .info-box {
        background: #f8f8f8;
        border-radius: 10px;
        padding: 12px 15px;
        border: 1px solid #f0f0f0;
    }

        .info-box .ib-label {
            font-size: 10.5px;
            font-weight: 600;
            color: #aaa;
            text-transform: uppercase;
            letter-spacing: 0.7px;
            margin-bottom: 4px;
        }

        .info-box .ib-value {
            font-size: 14px;
            font-weight: 600;
            color: #1a1a2e;
        }

    /* Status pill inline */
    .sp-inline {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 9px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
    }

        .sp-inline.pending {
            background: #fff8e6;
            color: #b7770d;
            border: 1px solid #f5d87a;
        }

        .sp-inline.completed {
            background: #e8f8f0;
            color: #1a7a47;
            border: 1px solid #b7e4cc;
        }

        .sp-inline.cancelled {
            background: #fef3f2;
            color: #C0392B;
            border: 1px solid rgba(192,57,43,0.25);
        }

    .sp-dot-s {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
    }

    /* Items table */
    .items-label {
        font-size: 11.5px;
        font-weight: 700;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .items-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #eee;
        }

    .items-tbl {
        width: 100%;
        border-collapse: collapse;
    }

        .items-tbl thead tr {
            background: linear-gradient(135deg,#C0392B,#8B1A14);
        }

        .items-tbl thead th {
            padding: 9px 13px;
            font-size: 12px;
            font-weight: 600;
            color: #fff;
            border: none;
            text-align: left;
        }

        .items-tbl tbody tr {
            border-bottom: 1px solid #f5f5f5;
        }

            .items-tbl tbody tr:last-child {
                border-bottom: none;
            }

        .items-tbl tbody td {
            padding: 9px 13px;
            font-size: 13.5px;
            color: #444;
        }

    .grand-total {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 14px;
        margin-top: 14px;
        padding-top: 12px;
        border-top: 1px solid #eee;
    }

    .grand-label {
        font-size: 13px;
        color: #888;
    }

    .grand-value {
        font-size: 18px;
        font-weight: 700;
        color: #C0392B;
    }

    .modal-footer-custom {
        padding: 14px 22px;
        background: #fafafa;
        border-top: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-close-modal {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 18px;
        background: transparent;
        color: #555;
        border: 1.5px solid #e0e0e0;
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
        transition: border-color 0.2s,color 0.2s;
    }

        .btn-close-modal:hover {
            border-color: #C0392B;
            color: #C0392B;
        }

    .btn-print-modal {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 20px;
        background: linear-gradient(135deg,#C0392B,#8B1A14);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s;
    }

        .btn-print-modal:hover {
            opacity: 0.9;
        }
</style>

<!-- Modal Header -->
<div class="modal-header-custom">
    <h5>
        <i class="fa fa-file-invoice"></i>
        Order Details — #@Model.OrderID
    </h5>
    <button class="modal-close-btn" data-bs-dismiss="modal" data-dismiss="modal">
        <i class="fa fa-xmark"></i>
    </button>
</div>

<!-- Modal Body -->
<div class="modal-body-custom" id="printArea">

    <!-- Order info grid -->
    <div class="order-info-grid">
        <div class="info-box">
            <div class="ib-label">Customer</div>
            <div class="ib-value">@(Model.User != null ? Model.User.Name : "N/A")</div>
        </div>
        <div class="info-box">
            <div class="ib-label">Email</div>
            <div class="ib-value" style="font-size:13px;">@(Model.User != null ? Model.User.Email : "N/A")</div>
        </div>
        <div class="info-box">
            <div class="ib-label">Order Date</div>
            <div class="ib-value">@(Model.OrderDate.HasValue ? Model.OrderDate.Value.ToString("MMM dd, yyyy · hh:mm tt") : "—")</div>
        </div>
        <div class="info-box">
            <div class="ib-label">Status</div>
            <div class="ib-value">
                @{
                    string sc = Model.Status == "Pending" ? "pending"
                              : Model.Status == "Completed" ? "completed"
                              : Model.Status == "Cancelled" ? "cancelled" : "";
                }
                <span class="sp-inline @sc">
                    <span class="sp-dot-s"></span> @Model.Status
                </span>
            </div>
        </div>
    </div>

    <!-- Items -->
    <div class="items-label">Ordered Items (@Model.OrderItems.Count)</div>
    <table class="items-tbl">
        <thead>
            <tr>
                <th>Product</th>
                <th style="text-align:center;">Qty</th>
                <th style="text-align:right;">Unit Price</th>
                <th style="text-align:right;">Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderItems)
            {
                <tr>
                    <td style="font-weight:600;color:#1a1a2e;">@(item.Product != null ? item.Product.Name : "N/A")</td>
                    <td style="text-align:center;">@item.Quantity</td>
                    <td style="text-align:right;">Rs. @item.Price.ToString("N0")</td>
                    <td style="text-align:right;font-weight:700;">Rs. @((item.Price * item.Quantity).ToString("N0"))</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Grand total -->
    <div class="grand-total">
        <span class="grand-label">Grand Total</span>
        <span class="grand-value">Rs. @Model.TotalAmount.ToString("N0")</span>
    </div>

</div>

<!-- Modal Footer -->
<div class="modal-footer-custom">
    <button class="btn-close-modal" data-bs-dismiss="modal" data-dismiss="modal">
        <i class="fa fa-times"></i> Close
    </button>
    <button class="btn-print-modal" onclick="printOrderDetails()">
        <i class="fa fa-print"></i> Print
    </button>
</div>

<script>
    function printOrderDetails() {
        var content = document.getElementById("printArea").innerHTML;
        var win = window.open('', '', 'height=700,width=900');
        win.document.write('<html><head><title>Order #@Model.OrderID</title>');
        win.document.write('<style>body{font-family:Arial,sans-serif;padding:20px;} table{width:100%;border-collapse:collapse;} th,td{padding:8px 12px;border:1px solid #ddd;} th{background:#C0392B;color:#fff;}</style>');
        win.document.write('</head><body>');
        win.document.write('<h2>MARS Mobile Shop — Order #@Model.OrderID</h2>');
        win.document.write(content);
        win.document.write('</body></html>');
        win.document.close();
        win.print();
    }
</script>
