@model MARS_Project.Models.User
@{
    ViewBag.Title = "Delete User";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="card">
    <div class="card-header bg-danger text-white">
        <h3><i class="fas fa-trash"></i> Delete User</h3>
    </div>
    <div class="card-body">
        <h4>Are you sure you want to delete this user?</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Role</dt>
            <dd class="col-sm-9">@Model.UserType?.UserTypeName</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>

        @using (Html.BeginForm("DeleteUser", "Admin", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.UserID)

            <button type="submit" class="btn btn-danger">
                <i class="fas fa-trash"></i> Confirm Delete
            </button>
            @Html.ActionLink("Cancel", "ManageUsers", null, new { @class = "btn btn-secondary ms-2" })
        }
    </div>
</div>
