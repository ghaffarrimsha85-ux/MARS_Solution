@model IEnumerable<MARS_Project.Models.User>
@{
    ViewBag.Title = "Pending Users";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="card">
    <div class="card-header">
        <div class="card-title"> <h3 style="color:darkslateblue; font-size:40px">All Pending Users</h3></div>

    </div>
    <div class="card-body">

        <hr />
        <table class="table table-striped my-4 w-100" id="datatable2">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>@user.UserType.UserTypeName</td>
                        <td>
                            <div class="d-flex gap-2">
                                <button class="btn btn-success btn-sm btn-approve" data-id="@user.UserID">
                                    <i class="fa fa-check"></i>
                                </button>

                                <button class="btn btn-danger btn-sm btn-reject" data-id="@user.UserID">
                                    <i class="fa fa-times"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>


        </table>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // 🟢 Approve User
    document.querySelectorAll(".btn-approve").forEach(btn => {
        btn.addEventListener("click", () => {
            const id = btn.getAttribute("data-id");

            Swal.fire({
                title: "Approve this user?",
                text: "Once approved, the user will gain access.",
                icon: "question",
                showCancelButton: true,
                confirmButtonColor: "#28a745",
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Yes, approve!"
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `/Admin/ApproveUser/${id}`;
                }
            });
        });
    });

    // 🔴 Reject User
    document.querySelectorAll(".btn-reject").forEach(btn => {
        btn.addEventListener("click", () => {
            const id = btn.getAttribute("data-id");

            Swal.fire({
                title: "Reject this user?",
                text: "The user will not be able to log in.",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Yes, reject!"
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `/Admin/RejectUser/${id}`;
                }
            });
        });
    });

    // ✅ Show success alert (after redirect)
    @if (TempData["Message"] != null)
    {
        <text>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["Message"]',
                confirmButtonColor: '#3085d6'
            });
        </text>
    }
    </script>
   
  
}
