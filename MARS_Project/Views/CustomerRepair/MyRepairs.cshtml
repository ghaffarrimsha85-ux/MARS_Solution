@model IEnumerable<MARS_Project.Models.RepairRequest>
@{
    ViewBag.Title = "My Repair Requests";
    Layout = "~/Views/Shared/_LayoutCustomer.cshtml";
}

<style>
    /* ─── Hero ─── */
    .repairs-hero {
        background: linear-gradient(135deg, #1a0a08 0%, #C0392B 60%, #8B1A14 100%);
        padding: 48px 0 90px;
        position: relative;
        overflow: hidden;
    }

    .repairs-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
        background-size: 40px 40px;
    }

    .repairs-hero::after {
        content: '';
        position: absolute;
        bottom: -1px; left: 0; right: 0;
        height: 60px;
        background: #f6f7fb;
        clip-path: ellipse(55% 100% at 50% 100%);
    }

    .hero-inner {
        position: relative;
        z-index: 2;
        text-align: center;
        color: #fff;
    }

    .hero-inner .page-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.6);
        margin-bottom: 6px;
    }

    .hero-inner h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 14px;
    }

    .hero-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 18px;
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 20px;
        color: #fff;
        font-size: 13px;
        text-decoration: none;
        transition: background 0.2s;
    }
    .hero-back-btn:hover { background: rgba(255,255,255,0.28); color: #fff; }

    /* ─── Page wrapper ─── */
    .repairs-wrapper {
        max-width: 820px;
        margin: -55px auto 0;
        padding: 0 16px 60px;
        position: relative;
        z-index: 5;
    }

    /* ─── Top action bar ─── */
    .action-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 20px;
    }

    .action-bar .total-count {
        font-size: 13.5px;
        color: #888;
    }

    .action-bar .total-count strong { color: #1a1a2e; }

    .btn-new-request {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 20px;
        background: linear-gradient(135deg, #C0392B, #8B1A14);
        color: #fff;
        border-radius: 11px;
        font-size: 13.5px;
        font-weight: 600;
        text-decoration: none;
        box-shadow: 0 4px 14px rgba(192,57,43,0.28);
        transition: opacity 0.2s, transform 0.15s;
    }
    .btn-new-request:hover { opacity: 0.9; color: #fff; transform: translateY(-1px); }

    /* ─── Empty state ─── */
    .empty-state {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #eee;
        box-shadow: 0 8px 32px rgba(0,0,0,0.06);
        padding: 56px 24px;
        text-align: center;
    }

    .empty-icon {
        width: 80px; height: 80px;
        background: #fef3f2;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 18px;
    }

    .empty-icon i { font-size: 32px; color: #C0392B; }

    .empty-state h4 {
        font-size: 17px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 8px;
    }

    .empty-state p {
        font-size: 13.5px;
        color: #aaa;
        margin-bottom: 22px;
    }

    /* ─── Repair Card ─── */
    .repair-card {
        background: #fff;
        border-radius: 18px;
        border: 1px solid #eee;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        overflow: hidden;
        margin-bottom: 16px;
        transition: box-shadow 0.2s;
    }

    .repair-card:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.09); }

    /* card top bar — colored by status */
    .repair-card-top {
        height: 4px;
        width: 100%;
    }

    .repair-card-top.pending    { background: linear-gradient(90deg, #f39c12, #e67e22); }
    .repair-card-top.inprogress { background: linear-gradient(90deg, #2980b9, #3498db); }
    .repair-card-top.completed  { background: linear-gradient(90deg, #1a7a47, #27ae60); }
    .repair-card-top.other      { background: linear-gradient(90deg, #95a5a6, #bdc3c7); }

    .repair-card-body {
        padding: 18px 20px;
        display: flex;
        align-items: flex-start;
        gap: 16px;
    }

    /* request # badge */
    .req-num {
        width: 44px; height: 44px;
        background: #fef3f2;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        flex-shrink: 0;
    }

    .req-num span:first-child {
        font-size: 9px;
        font-weight: 700;
        color: #C0392B;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .req-num span:last-child {
        font-size: 15px;
        font-weight: 700;
        color: #C0392B;
        line-height: 1;
    }

    /* content area */
    .repair-content { flex: 1; min-width: 0; }

    .repair-desc {
        font-size: 14px;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 8px;
        line-height: 1.45;
        /* 2 line clamp */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .repair-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        color: #aaa;
        font-weight: 500;
    }

    .meta-item i { font-size: 11px; color: #C0392B; }

    /* status badge */
    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 11px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 700;
        letter-spacing: 0.3px;
    }

    .status-pill.pending {
        background: #fff8e6;
        color: #b7770d;
        border: 1px solid #f5d87a;
    }

    .status-pill.inprogress {
        background: #eef5ff;
        color: #1a5fa8;
        border: 1px solid #aecbf5;
    }

    .status-pill.completed {
        background: #e8f8f0;
        color: #1a7a47;
        border: 1px solid #b7e4cc;
    }

    .status-pill.other {
        background: #f4f4f4;
        color: #888;
        border: 1px solid #ddd;
    }

    .status-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    /* right side */
    .repair-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 10px;
        flex-shrink: 0;
    }

    /* image thumbnails */
    .img-thumbs {
        display: flex;
        gap: 6px;
    }

    .img-thumb {
        width: 40px; height: 40px;
        border-radius: 8px;
        overflow: hidden;
        border: 1.5px solid #eee;
        flex-shrink: 0;
    }

    .img-thumb img {
        width: 100%; height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.2s;
    }

    .img-thumb:hover img { transform: scale(1.1); }

    .img-thumb-placeholder {
        width: 40px; height: 40px;
        border-radius: 8px;
        background: #f5f5f5;
        border: 1.5px dashed #ddd;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ccc;
        font-size: 14px;
    }

    /* Response section if exists */
    .repair-response {
        border-top: 1px solid #f0f0f0;
        padding: 14px 20px;
        background: #fafafa;
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }

    .response-icon {
        width: 32px; height: 32px;
        background: linear-gradient(135deg, #C0392B, #8B1A14);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 13px;
        flex-shrink: 0;
    }

    .response-content { flex: 1; }

    .response-label {
        font-size: 11px;
        font-weight: 700;
        color: #C0392B;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 4px;
    }

    .response-text {
        font-size: 13px;
        color: #555;
        line-height: 1.5;
        margin-bottom: 6px;
    }

    .response-meta {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .response-meta-item {
        font-size: 12px;
        font-weight: 600;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .response-meta-item i { color: #C0392B; font-size: 11px; }

    @@media (max-width: 576px) {
        .repairs-hero { padding: 36px 0 80px; }
        .repairs-wrapper { margin-top: -50px; }
        .repair-card-body { flex-direction: column; gap: 12px; }
        .repair-right { align-items: flex-start; flex-direction: row; }
        .action-bar { flex-direction: column; align-items: stretch; }
        .btn-new-request { justify-content: center; }
    }
</style>

<!-- Hero -->
<div class="repairs-hero">
    <div class="container hero-inner">
        <div class="page-label">Support</div>
        <h1><i class="fa fa-list-check me-2"></i>My Repair Requests</h1>
        <a href="@Url.Action("Index","CustomerProduct")" class="hero-back-btn">
            <i class="fa fa-home"></i> Home
        </a>
    </div>
</div>

<!-- Content -->
<div class="repairs-wrapper">

    <!-- Action bar -->
    <div class="action-bar">
        <div class="total-count">
            Total: <strong>@Model.Count() request@(Model.Count() != 1 ? "s" : "")</strong>
        </div>
        <a href="@Url.Action("SubmitRepair","CustomerRepair")" class="btn-new-request">
            <i class="fa fa-plus"></i> New Request
        </a>
    </div>

    @if (!Model.Any())
    {
        <!-- Empty state -->
        <div class="empty-state">
            <div class="empty-icon"><i class="fa fa-tools"></i></div>
            <h4>No Repair Requests Yet</h4>
            <p>You haven't submitted any repair requests. Submit one and our technician will get back to you.</p>
            <a href="@Url.Action("SubmitRepair","CustomerRepair")" class="btn-new-request">
                <i class="fa fa-paper-plane"></i> Submit a Request
            </a>
        </div>
    }
    else
    {
        foreach (var r in Model)
        {
            string statusClass = r.Status == "Pending" ? "pending"
                               : r.Status == "In Progress" ? "inprogress"
                               : r.Status == "Completed" ? "completed"
                               : "other";

            <div class="repair-card">
                <!-- colored top bar -->
                <div class="repair-card-top @statusClass"></div>

                <div class="repair-card-body">
                    <!-- Request number -->
                    <div class="req-num">
                        <span>REQ</span>
                        <span>#@r.RequestID</span>
                    </div>

                    <!-- Content -->
                    <div class="repair-content">
                        <div class="repair-desc">@r.ProblemDescription</div>
                        <div class="repair-meta">
                            <div class="meta-item">
                                <i class="fa fa-calendar"></i>
                                @(r.RequestDate.HasValue ? r.RequestDate.Value.ToString("MMM dd, yyyy") : "—")
                            </div>
                            <div class="meta-item">
                                <i class="fa fa-clock"></i>
                                @(r.RequestDate.HasValue ? r.RequestDate.Value.ToString("hh:mm tt") : "")
                            </div>

                            <!-- Status pill -->
                            <span class="status-pill @statusClass">
                                <span class="status-dot"></span>
                                @r.Status
                            </span>
                        </div>
                    </div>

                    <!-- Right: images -->
                    <div class="repair-right">
                        <div class="img-thumbs">
                            @if (!string.IsNullOrEmpty(r.ProblemImage1))
                            {
                                <a href="@r.ProblemImage1" target="_blank" class="img-thumb" title="Photo 1">
                                    <img src="@r.ProblemImage1" alt="Photo 1" />
                                </a>
                            }
                            else
                            {
                                <div class="img-thumb-placeholder"><i class="fa fa-image"></i></div>
                            }

                            @if (!string.IsNullOrEmpty(r.ProblemImage2))
                            {
                                <a href="@r.ProblemImage2" target="_blank" class="img-thumb" title="Photo 2">
                                    <img src="@r.ProblemImage2" alt="Photo 2" />
                                </a>
                            }
                            else
                            {
                                <div class="img-thumb-placeholder"><i class="fa fa-image"></i></div>
                            }

                            @if (!string.IsNullOrEmpty(r.ProblemImage3))
                            {
                                <a href="@r.ProblemImage3" target="_blank" class="img-thumb" title="Photo 3">
                                    <img src="@r.ProblemImage3" alt="Photo 3" />
                                </a>
                            }
                            else
                            {
                                <div class="img-thumb-placeholder"><i class="fa fa-image"></i></div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Employee Response (if any) -->
                @if (r.RepairResponses != null && r.RepairResponses.Any())
                {
                    var resp = r.RepairResponses.FirstOrDefault();
                    <div class="repair-response">
                        <div class="response-icon"><i class="fa fa-user-tie"></i></div>
                        <div class="response-content">
                            <div class="response-label">Technician Response</div>
                            <div class="response-text">@resp.SolutionDesc</div>
                            <div class="response-meta">
                                @if (resp.EstimatedCost.HasValue)
                                {
                                    <div class="response-meta-item">
                                        <i class="fa fa-tag"></i> Rs. @resp.EstimatedCost.Value.ToString("N0")
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(resp.EstimatedTime))
                                {
                                    <div class="response-meta-item">
                                        <i class="fa fa-clock"></i> @resp.EstimatedTime
                                    </div>
                                }
                                @if (resp.ResponseDate.HasValue)
                                {
                                    <div class="response-meta-item">
                                        <i class="fa fa-calendar-check"></i>
                                        @resp.ResponseDate.Value.ToString("MMM dd, yyyy")
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

            </div>
        }
    }

</div>
