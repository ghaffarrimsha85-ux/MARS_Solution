<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewBag.Title — MARS Employee</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css" rel="stylesheet" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --sidebar-w: 240px;
            --sidebar-collapsed: 70px;
            --mars-red: #C0392B;
            --mars-dark: #1a0a08;
            --mars-mid: #2d1008;
            --mars-gold: #E8C97A;
            --topbar-h: 64px;
            --bg: #f0f2f8;
            --text: #1a1a2e;
            --muted: #888;
            --border: #eee;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
        }

        /* ══════════════════════════════
           SIDEBAR
        ══════════════════════════════ */
        .sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: var(--mars-dark);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 200;
            transition: width 0.25s ease;
            overflow: hidden;
        }

        body.sidebar-collapsed .sidebar { width: var(--sidebar-collapsed); }

        /* Brand */
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 20px 18px;
            text-decoration: none;
            border-bottom: 1px solid rgba(255,255,255,0.07);
            flex-shrink: 0;
        }

        .sidebar-brand-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, var(--mars-red), #8B1A14);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 16px;
            flex-shrink: 0;
        }

        .sidebar-brand-text {
            font-size: 15px;
            font-weight: 700;
            color: #fff;
            white-space: nowrap;
            line-height: 1.2;
        }

        .sidebar-brand-text small {
            display: block;
            font-size: 10px;
            font-weight: 400;
            color: rgba(255,255,255,0.45);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* Employee info */
        .sidebar-user {
            padding: 16px 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
            flex-shrink: 0;
        }

        .sidebar-avatar {
            width: 36px; height: 36px;
            border-radius: 50%;
            background: rgba(255,255,255,0.12);
            display: flex; align-items: center; justify-content: center;
            color: var(--mars-gold);
            font-size: 15px;
            flex-shrink: 0;
            border: 1.5px solid rgba(232,201,122,0.3);
        }

        .sidebar-user-info { min-width: 0; }

        .sidebar-user-name {
            font-size: 13px;
            font-weight: 600;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .sidebar-user-role {
            font-size: 10.5px;
            color: var(--mars-gold);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            font-weight: 500;
        }

        /* Nav section label */
        .nav-section-label {
            font-size: 9.5px;
            font-weight: 700;
            color: rgba(255,255,255,0.3);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 16px 18px 6px;
            white-space: nowrap;
            overflow: hidden;
        }

        /* Nav links */
        .sidebar-nav { flex: 1; overflow-y: auto; padding-bottom: 16px; }
        .sidebar-nav::-webkit-scrollbar { width: 0; }

        .nav-item {
            display: block;
            margin: 2px 10px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            border-radius: 10px;
            color: rgba(255,255,255,0.65) !important;
            font-size: 13.5px;
            font-weight: 500;
            text-decoration: none;
            transition: background 0.18s, color 0.18s;
            white-space: nowrap;
            overflow: hidden;
        }

        .nav-link .nav-icon {
            width: 20px; height: 20px;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
            color: rgba(255,255,255,0.45);
            transition: color 0.18s;
        }

        .nav-link:hover {
            background: rgba(255,255,255,0.08);
            color: #fff !important;
        }

        .nav-link:hover .nav-icon { color: var(--mars-gold); }

        .nav-link.active {
            background: linear-gradient(135deg, var(--mars-red), #8B1A14) !important;
            color: #fff !important;
        }

        .nav-link.active .nav-icon { color: #fff; }

        /* Logout special */
        .nav-link.logout-link:hover {
            background: rgba(192,57,43,0.2) !important;
            color: #f5a49a !important;
        }

        .nav-link.logout-link .nav-icon { color: rgba(192,57,43,0.6); }

        /* Sidebar footer */
        .sidebar-footer {
            padding: 14px 18px;
            border-top: 1px solid rgba(255,255,255,0.07);
            flex-shrink: 0;
        }

        .sidebar-toggle-btn {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px;
            background: rgba(255,255,255,0.06);
            border: none;
            border-radius: 8px;
            color: rgba(255,255,255,0.5);
            font-size: 13px;
            cursor: pointer;
            transition: background 0.18s, color 0.18s;
            white-space: nowrap;
            overflow: hidden;
        }

        .sidebar-toggle-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }

        /* ══════════════════════════════
           MAIN CONTENT
        ══════════════════════════════ */
        .main-wrap {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            transition: margin-left 0.25s ease;
        }

        body.sidebar-collapsed .main-wrap { margin-left: var(--sidebar-collapsed); }

        /* ══════════════════════════════
           TOPBAR
        ══════════════════════════════ */
        .topbar {
            height: var(--topbar-h);
            background: rgba(255,255,255,0.97);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 24px;
            gap: 16px;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 16px rgba(0,0,0,0.05);
        }

        .topbar-mobile-toggle {
            display: none;
            background: none;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            padding: 6px 9px;
            cursor: pointer;
            color: #555;
            font-size: 15px;
        }

        .topbar-breadcrumb {
            flex: 1;
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .topbar-breadcrumb .bc-icon {
            width: 30px; height: 30px;
            background: #fef3f2;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            color: var(--mars-red);
            font-size: 13px;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-date {
            font-size: 12px;
            color: var(--muted);
            background: #f5f5f5;
            padding: 5px 12px;
            border-radius: 8px;
            white-space: nowrap;
        }

        .topbar-avatar {
            width: 36px; height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--mars-red), #8B1A14);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 14px;
            border: 2px solid rgba(192,57,43,0.25);
            cursor: pointer;
            text-decoration: none;
        }

        /* ══════════════════════════════
           PAGE CONTENT
        ══════════════════════════════ */
        .page-content {
            flex: 1;
            padding: 24px;
        }

        /* ══════════════════════════════
           FOOTER
        ══════════════════════════════ */
        .site-footer {
            background: #fff;
            border-top: 1px solid var(--border);
            padding: 14px 24px;
            text-align: center;
            font-size: 12.5px;
            color: var(--muted);
        }

        .site-footer strong { color: var(--mars-red); }

        /* ══════════════════════════════
           DATATABLES override
        ══════════════════════════════ */
        table.dataTable thead {
            background: linear-gradient(135deg, var(--mars-red), #8B1A14);
            color: #fff;
        }

        table.dataTable thead th { border: none !important; }

        .dt-buttons .dt-button {
            background: var(--mars-red) !important;
            color: #fff !important;
            border: none !important;
            border-radius: 7px !important;
            padding: 6px 14px !important;
            font-size: 13px !important;
            font-family: 'DM Sans', sans-serif !important;
            transition: opacity 0.2s !important;
        }

        .dt-buttons .dt-button:hover { opacity: 0.85 !important; }

        .dataTables_wrapper .dataTables_filter input {
            border-radius: 7px; border: 1.5px solid #e0e0e0;
            padding: 5px 10px; font-family: 'DM Sans', sans-serif;
        }

        .dataTables_wrapper .dataTables_filter input:focus {
            border-color: var(--mars-red); outline: none;
            box-shadow: 0 0 0 3px rgba(192,57,43,0.1);
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            border-radius: 7px !important;
            margin: 0 2px !important;
            font-family: 'DM Sans', sans-serif !important;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: var(--mars-red) !important;
            color: white !important;
            border: none !important;
        }

        /* ══════════════════════════════
           MOBILE
        ══════════════════════════════ */
        @@media (max-width: 900px) {
            .sidebar {
                left: calc(-1 * var(--sidebar-w));
                transition: left 0.25s ease, width 0.25s ease;
            }

            body.mobile-open .sidebar {
                left: 0;
                width: var(--sidebar-w);
            }

            .main-wrap { margin-left: 0 !important; }
            .topbar-mobile-toggle { display: flex; }

            body.mobile-open::after {
                content: '';
                position: fixed; inset: 0;
                background: rgba(0,0,0,0.4);
                z-index: 199;
            }
        }
    </style>
</head>
<body id="page-top">

    <!-- ══════════ SIDEBAR ══════════ -->
    <aside class="sidebar" id="sidebar">

        <!-- Brand -->
        <a href="@Url.Action("EmployeeDashboard","Dashboard")" class="sidebar-brand">
            <div class="sidebar-brand-icon">
                <i class="fa fa-mobile-screen-button"></i>
            </div>
            <div class="sidebar-brand-text">
                MARS
                <small>Employee Panel</small>
            </div>
        </a>

        <!-- User info -->
        <div class="sidebar-user">
            <div class="sidebar-avatar"><i class="fa fa-user-tie"></i></div>
            <div class="sidebar-user-info">
                <div class="sidebar-user-name">@Session["UserName"]</div>
                <div class="sidebar-user-role">Employee</div>
            </div>
        </div>

        <!-- Nav -->
        <nav class="sidebar-nav">
            <div class="nav-section-label">Main</div>

            <div class="nav-item">
                <a href="@Url.Action("EmployeeDashboard","Dashboard")" class="nav-link @(ViewBag.Active == "dashboard" ? "active" : "")">
                    <span class="nav-icon"><i class="fa fa-gauge"></i></span>
                    <span>Dashboard</span>
                </a>
            </div>

            <div class="nav-section-label">Work</div>

            <div class="nav-item">
                <a href="@Url.Action("AssignedRequests","Employee")" class="nav-link @(ViewBag.Active == "requests" ? "active" : "")">
                    <span class="nav-icon"><i class="fa fa-wrench"></i></span>
                    <span>Repair Requests</span>
                </a>
            </div>

            <div class="nav-item">
                <a href="@Url.Action("MyResponses","Employee")" class="nav-link @(ViewBag.Active == "responses" ? "active" : "")">
                    <span class="nav-icon"><i class="fa fa-reply"></i></span>
                    <span>My Responses</span>
                </a>
            </div>

            <div class="nav-item">
                <a href="@Url.Action("Reports","Employee")" class="nav-link @(ViewBag.Active == "reports" ? "active" : "")">
                    <span class="nav-icon"><i class="fa fa-chart-line"></i></span>
                    <span>Reports</span>
                </a>
            </div>

            <div class="nav-section-label">Overview</div>

            <div class="nav-item">
                <a href="@Url.Action("ProductList","Employee")" class="nav-link @(ViewBag.Active == "products" ? "active" : "")">
                    <span class="nav-icon"><i class="fa fa-mobile-alt"></i></span>
                    <span>Products</span>
                </a>
            </div>

            <div class="nav-item">
                <a href="@Url.Action("RequestsList","Employee")" class="nav-link @(ViewBag.Active == "reqlist" ? "active" : "")">
                    <span class="nav-icon"><i class="fa fa-list-check"></i></span>
                    <span>All Requests</span>
                </a>
            </div>

            <div class="nav-item">
                <a href="@Url.Action("CustomerList","Employee")" class="nav-link @(ViewBag.Active == "customers" ? "active" : "")">
                    <span class="nav-icon"><i class="fa fa-users"></i></span>
                    <span>Customers</span>
                </a>
            </div>

            <div class="nav-section-label">Account</div>

            <div class="nav-item">
                <a href="@Url.Action("Profile","Employee")" class="nav-link @(ViewBag.Active == "profile" ? "active" : "")">
                    <span class="nav-icon"><i class="fa fa-user"></i></span>
                    <span>My Profile</span>
                </a>
            </div>

            <div class="nav-item">
                <a href="@Url.Action("Logout","Home")" class="nav-link logout-link" id="sidebarLogout">
                    <span class="nav-icon"><i class="fa fa-sign-out-alt"></i></span>
                    <span>Logout</span>
                </a>
            </div>
        </nav>

        <!-- Sidebar Footer Toggle -->
        <div class="sidebar-footer">
            <button class="sidebar-toggle-btn" id="collapseToggle">
                <i class="fa fa-chevron-left" id="toggleIcon"></i>
                <span id="toggleLabel">Collapse</span>
            </button>
        </div>
    </aside>

    <!-- ══════════ MAIN WRAP ══════════ -->
    <div class="main-wrap">

        <!-- Topbar -->
        <div class="topbar">
            <button class="topbar-mobile-toggle" id="mobileSidebarToggle">
                <i class="fa fa-bars"></i>
            </button>

            <div class="topbar-breadcrumb">
                <div class="bc-icon"><i class="fa fa-gauge"></i></div>
                @(ViewBag.Title ?? "Dashboard")
            </div>

            <div class="topbar-right">
                <span class="topbar-date">
                    <i class="fa fa-calendar" style="color:#C0392B;margin-right:5px;"></i>
                    @DateTime.Now.ToString("MMM dd, yyyy")
                </span>
                <a href="@Url.Action("Profile","Employee")" class="topbar-avatar" title="My Profile">
                    <i class="fa fa-user-tie"></i>
                </a>
            </div>
        </div>

        <!-- Page Content -->
        <div class="page-content">
            @RenderBody()
        </div>

        <!-- Footer -->
        <footer class="site-footer">
            &copy; @DateTime.Now.Year <strong>MARS Mobile Shop</strong> — Employee Panel
        </footer>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // ── Collapse sidebar (desktop)
        const collapseBtn = document.getElementById('collapseToggle');
        const toggleIcon = document.getElementById('toggleIcon');
        const toggleLabel = document.getElementById('toggleLabel');

        collapseBtn?.addEventListener('click', function () {
            document.body.classList.toggle('sidebar-collapsed');
            const collapsed = document.body.classList.contains('sidebar-collapsed');
            toggleIcon.className = collapsed ? 'fa fa-chevron-right' : 'fa fa-chevron-left';
            toggleLabel.textContent = collapsed ? 'Expand' : 'Collapse';
        });

        // ── Mobile sidebar toggle
        document.getElementById('mobileSidebarToggle')?.addEventListener('click', function () {
            document.body.classList.toggle('mobile-open');
        });

        // close mobile sidebar on overlay click
        document.addEventListener('click', function (e) {
            if (document.body.classList.contains('mobile-open')) {
                const sidebar = document.getElementById('sidebar');
                const toggle = document.getElementById('mobileSidebarToggle');
                if (!sidebar.contains(e.target) && e.target !== toggle) {
                    document.body.classList.remove('mobile-open');
                }
            }
        });

        // ── Logout confirm
        document.getElementById('sidebarLogout')?.addEventListener('click', function (e) {
            e.preventDefault();
            var href = this.href;
            Swal.fire({
                title: 'Logging out?',
                text: 'Are you sure you want to end this session?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#C0392B',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, logout',
                cancelButtonText: 'Cancel'
            }).then((r) => { if (r.isConfirmed) window.location.href = href; });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
