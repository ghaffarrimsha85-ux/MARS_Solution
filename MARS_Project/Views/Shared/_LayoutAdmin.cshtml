<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewBag.Title — MARS Admin</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css" rel="stylesheet" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --sidebar-w: 248px;
            --sidebar-col: 68px;
            --topbar-h: 62px;
            --mars-red: #C0392B;
            --mars-dark: #12090700;
            --mars-darker: #0d0403;
            --mars-mid: #1a0a08;
            --mars-gold: #E8C97A;
            --bg: #f0f2f8;
            --text: #1a1a2e;
            --muted: #888;
            --border: #eee;
            --white: #fff;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        /* ══════════════ SIDEBAR ══════════════ */
        .sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: linear-gradient(180deg, #1a0a08 0%, #0d0403 100%);
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 300;
            display: flex;
            flex-direction: column;
            transition: width 0.25s ease;
            overflow: hidden;
        }

        body.collapsed .sidebar { width: var(--sidebar-col); }

        /* Gold top accent */
        .sidebar::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--mars-red), var(--mars-gold));
        }

        /* Brand */
        .s-brand {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 22px 18px 18px;
            text-decoration: none;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            flex-shrink: 0;
        }

        .s-brand-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, var(--mars-red), #8B1A14);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 16px;
            flex-shrink: 0;
            box-shadow: 0 4px 12px rgba(192,57,43,0.4);
        }

        .s-brand-text { white-space: nowrap; overflow: hidden; }
        .s-brand-text strong { display: block; font-size: 15px; font-weight: 700; color: #fff; }
        .s-brand-text small  { font-size: 10px; font-weight: 400; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px; }

        /* Admin info */
        .s-user {
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            flex-shrink: 0;
        }

        .s-avatar {
            width: 34px; height: 34px;
            border-radius: 50%;
            background: rgba(255,255,255,0.1);
            display: flex; align-items: center; justify-content: center;
            color: var(--mars-gold); font-size: 14px;
            border: 1.5px solid rgba(232,201,122,0.3);
            flex-shrink: 0;
        }

        .s-user-info { min-width: 0; }
        .s-user-name { font-size: 12.5px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .s-user-role { font-size: 10px; color: var(--mars-gold); text-transform: uppercase; letter-spacing: 0.8px; font-weight: 500; }

        /* Section label */
        .s-section-label {
            font-size: 9.5px;
            font-weight: 700;
            color: rgba(255,255,255,0.28);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 14px 18px 5px;
            white-space: nowrap;
            overflow: hidden;
        }

        /* Nav */
        .s-nav { flex: 1; overflow-y: auto; padding-bottom: 12px; }
        .s-nav::-webkit-scrollbar { width: 0; }

        .s-item { display: block; margin: 2px 10px; }

        .s-link {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 9px 11px;
            border-radius: 10px;
            color: rgba(255,255,255,0.6) !important;
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            transition: background 0.18s, color 0.18s;
            white-space: nowrap;
            overflow: hidden;
        }

        .s-link .s-icon {
            width: 20px; height: 20px;
            display: flex; align-items: center; justify-content: center;
            font-size: 13.5px;
            color: rgba(255,255,255,0.4);
            flex-shrink: 0;
            transition: color 0.18s;
        }

        .s-link:hover { background: rgba(255,255,255,0.07); color: #fff !important; }
        .s-link:hover .s-icon { color: var(--mars-gold); }

        .s-link.active {
            background: linear-gradient(135deg, var(--mars-red), #8B1A14) !important;
            color: #fff !important;
            box-shadow: 0 3px 10px rgba(192,57,43,0.35);
        }

        .s-link.active .s-icon { color: #fff; }

        /* Badge on nav */
        .s-badge {
            margin-left: auto;
            background: var(--mars-red);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 10px;
            flex-shrink: 0;
        }

        /* Logout */
        .s-link.logout:hover { background: rgba(192,57,43,0.2) !important; color: #f5a49a !important; }
        .s-link.logout .s-icon { color: rgba(192,57,43,0.5); }

        /* Sidebar footer */
        .s-footer {
            padding: 12px 18px;
            border-top: 1px solid rgba(255,255,255,0.06);
            flex-shrink: 0;
        }

        .s-collapse-btn {
            width: 100%;
            display: flex; align-items: center; gap: 9px;
            padding: 8px 10px;
            background: rgba(255,255,255,0.05);
            border: none; border-radius: 8px;
            color: rgba(255,255,255,0.45);
            font-size: 12.5px;
            cursor: pointer;
            transition: background 0.18s, color 0.18s;
            white-space: nowrap; overflow: hidden;
        }

        .s-collapse-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }

        /* ══════════════ MAIN WRAP ══════════════ */
        .main-wrap {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left 0.25s ease;
        }

        body.collapsed .main-wrap { margin-left: var(--sidebar-col); }

        /* ══════════════ TOPBAR ══════════════ */
        .topbar {
            height: var(--topbar-h);
            background: rgba(255,255,255,0.97);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 22px;
            gap: 14px;
            position: sticky;
            top: 0; z-index: 200;
            box-shadow: 0 2px 14px rgba(0,0,0,0.05);
        }

        .topbar-mobile-btn {
            display: none;
            background: none;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            padding: 5px 9px;
            cursor: pointer;
            color: #555; font-size: 15px;
        }

        .topbar-title {
            flex: 1;
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .topbar-title .t-icon {
            width: 30px; height: 30px;
            background: #fef3f2;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            color: var(--mars-red); font-size: 13px;
        }

        .topbar-right { display: flex; align-items: center; gap: 10px; }

        .topbar-date {
            font-size: 12px; color: var(--muted);
            background: #f5f5f5;
            padding: 5px 12px; border-radius: 8px;
            white-space: nowrap;
        }

        /* Notification bell */
        .notif-btn {
            width: 36px; height: 36px;
            background: #fef3f2;
            border: none; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: var(--mars-red); font-size: 14px;
            cursor: pointer;
            position: relative;
            text-decoration: none;
        }

        .notif-dot {
            position: absolute;
            top: 6px; right: 7px;
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--mars-red);
            border: 2px solid #fff;
        }

        .topbar-avatar {
            width: 36px; height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--mars-red), #8B1A14);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 14px;
            border: 2.5px solid rgba(192,57,43,0.25);
            cursor: pointer; text-decoration: none;
        }

        /* ══════════════ CONTENT ══════════════ */
        .page-content { flex: 1; padding: 22px; }

        /* ══════════════ FOOTER ══════════════ */
        .site-footer {
            background: var(--white);
            border-top: 1px solid var(--border);
            padding: 13px 22px;
            text-align: center;
            font-size: 12.5px;
            color: var(--muted);
        }

        .site-footer strong { color: var(--mars-red); }

        /* ══════════════ DATATABLES ══════════════ */
        table.dataTable thead {
            background: linear-gradient(135deg, var(--mars-red), #8B1A14);
            color: #fff;
        }

        table.dataTable thead th { border: none !important; padding: 11px 14px !important; font-size: 12px !important; font-weight: 600 !important; }

        .dt-buttons .dt-button {
            background: var(--mars-red) !important;
            color: #fff !important;
            border: none !important;
            border-radius: 7px !important;
            padding: 6px 13px !important;
            font-size: 12.5px !important;
            font-family: 'DM Sans', sans-serif !important;
            margin-right: 4px !important;
        }

        .dt-buttons .dt-button:hover { opacity: 0.85 !important; }

        .dataTables_wrapper .dataTables_filter input {
            border: 1.5px solid #e0e0e0; border-radius: 8px;
            padding: 5px 10px; font-family: 'DM Sans', sans-serif; font-size: 13px;
        }

        .dataTables_wrapper .dataTables_filter input:focus {
            border-color: var(--mars-red); outline: none;
            box-shadow: 0 0 0 3px rgba(192,57,43,0.1);
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: var(--mars-red) !important;
            color: white !important; border: none !important;
            border-radius: 7px !important;
        }

        /* ══════════════ MOBILE ══════════════ */
        @@media (max-width: 900px) {
            .sidebar { left: calc(-1 * var(--sidebar-w)); transition: left 0.25s ease, width 0.25s ease; }
            body.mobile-open .sidebar { left: 0; width: var(--sidebar-w); }
            .main-wrap { margin-left: 0 !important; }
            .topbar-mobile-btn { display: flex; }
            body.mobile-open::after { content: ''; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 299; }
            .topbar-date { display: none; }
        }
    </style>
</head>
<body id="pageTop">

    <!-- ══════════ SIDEBAR ══════════ -->
    <aside class="sidebar" id="sidebar">

        <!-- Brand -->
        <a class="s-brand" href="@Url.Action("AdminDashboard","Dashboard")">
            <div class="s-brand-icon"><i class="fa fa-shield-halved"></i></div>
            <div class="s-brand-text">
                <strong>MARS Admin</strong>
                <small>Control Panel</small>
            </div>
        </a>

        <!-- Admin Info -->
        <div class="s-user">
            <div class="s-avatar"><i class="fa fa-user-shield"></i></div>
            <div class="s-user-info">
                <div class="s-user-name">@Session["UserName"]</div>
                <div class="s-user-role">Administrator</div>
            </div>
        </div>

        <!-- Nav -->
        <nav class="s-nav">

            <div class="s-section-label">Overview</div>

            <div class="s-item">
                <a href="@Url.Action("AdminDashboard","Dashboard")" class="s-link @(ViewBag.Active == "dashboard" ? "active" : "")">
                    <span class="s-icon"><i class="fa fa-gauge"></i></span>
                    <span>Dashboard</span>
                </a>
            </div>

            <div class="s-section-label">Management</div>

            <div class="s-item">
                <a href="@Url.Action("ManageUsers","Admin")" class="s-link @(ViewBag.Active == "users" ? "active" : "")">
                    <span class="s-icon"><i class="fa fa-users"></i></span>
                    <span>All Users</span>
                </a>
            </div>

            <div class="s-item">
                <a href="@Url.Action("ManageEmployees","Admin")" class="s-link @(ViewBag.Active == "employees" ? "active" : "")">
                    <span class="s-icon"><i class="fa fa-user-tie"></i></span>
                    <span>Employees</span>
                </a>
            </div>

            <div class="s-item">
                <a href="@Url.Action("ManageCustomers","Admin")" class="s-link @(ViewBag.Active == "customers" ? "active" : "")">
                    <span class="s-icon"><i class="fa fa-user"></i></span>
                    <span>Customers</span>
                </a>
            </div>

          @** <div class="s-item">
                <a href="@Url.Action("PendingUsers","Admin")" class="s-link @(ViewBag.Active == "pending" ? "active" : "")">
                    <span class="s-icon"><i class="fa fa-user-clock"></i></span>
                    <span>Pending Approvals</span>
                    @if (ViewBag.PendingCount != null && (int)ViewBag.PendingCount > 0)
                    {
                        <span class="s-badge">@ViewBag.PendingCount</span>
                    }
                </a>
            </div>*@

            <div class="s-section-label">Products & Orders</div>

            <div class="s-item">
                <a href="@Url.Action("ProductIndex","Product")" class="s-link @(ViewBag.Active == "products" ? "active" : "")">
                    <span class="s-icon"><i class="fa fa-mobile-alt"></i></span>
                    <span>Products</span>
                </a>
            </div>

            <div class="s-item">
                <a href="@Url.Action("Index","ProductCategories")" class="s-link @(ViewBag.Active == "categories" ? "active" : "")">
                    <span class="s-icon"><i class="fa fa-list"></i></span>
                    <span>Categories</span>
                </a>
            </div>

            <div class="s-item">
                <a href="@Url.Action("AllOrders","Admin")" class="s-link @(ViewBag.Active == "orders" ? "active" : "")">
                    <span class="s-icon"><i class="fa fa-box"></i></span>
                    <span>Orders</span>
                </a>
            </div>

            <div class="s-section-label">Repair</div>

            <div class="s-item">
                <a href="@Url.Action("RepairRequests","Admin")" class="s-link @(ViewBag.Active == "repairs" ? "active" : "")">
                    <span class="s-icon"><i class="fa fa-wrench"></i></span>
                    <span>Repair Requests</span>
                </a>
            </div>

            <div class="s-section-label">Account</div>

            <div class="s-item">
                <a href="@Url.Action("Profile","Admin")" class="s-link @(ViewBag.Active == "profile" ? "active" : "")">
                    <span class="s-icon"><i class="fa fa-user-shield"></i></span>
                    <span>My Profile</span>
                </a>
            </div>

            <div class="s-item">
                <a href="@Url.Action("Logout","Home")" class="s-link logout" id="sidebarLogout">
                    <span class="s-icon"><i class="fa fa-sign-out-alt"></i></span>
                    <span>Logout</span>
                </a>
            </div>

        </nav>

        <!-- Collapse toggle -->
        <div class="s-footer">
            <button class="s-collapse-btn" id="collapseBtn">
                <i class="fa fa-chevron-left" id="collapseIcon"></i>
                <span id="collapseLabel">Collapse</span>
            </button>
        </div>

    </aside>

    <!-- ══════════ MAIN ══════════ -->
    <div class="main-wrap">

        <!-- Topbar -->
        <div class="topbar">
            <button class="topbar-mobile-btn" id="mobileBtn">
                <i class="fa fa-bars"></i>
            </button>

            <div class="topbar-title">
                <div class="t-icon"><i class="fa fa-gauge"></i></div>
                @(ViewBag.Title ?? "Admin Panel")
            </div>

            <div class="topbar-right">
                <span class="topbar-date">
                    <i class="fa fa-calendar" style="color:#C0392B;margin-right:5px;"></i>
                    @DateTime.Now.ToString("MMM dd, yyyy")
                </span>
                <a class="notif-btn" href="#">
                    <i class="fa fa-bell"></i>
                    <span class="notif-dot"></span>
                </a>
                <a href="@Url.Action("Profile","Admin")" class="topbar-avatar" title="My Profile">
                    <i class="fa fa-user-shield"></i>
                </a>
            </div>
        </div>

        <!-- Content -->
        <div class="page-content">
            @RenderBody()
        </div>

        <!-- Footer -->
        <footer class="site-footer">
            &copy; @DateTime.Now.Year <strong>MARS Mobile Shop</strong> — Admin Control Panel
        </footer>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
    // Collapse sidebar
    document.getElementById('collapseBtn').addEventListener('click', function () {
        document.body.classList.toggle('collapsed');
        var c = document.body.classList.contains('collapsed');
        document.getElementById('collapseIcon').className  = c ? 'fa fa-chevron-right' : 'fa fa-chevron-left';
        document.getElementById('collapseLabel').textContent = c ? 'Expand' : 'Collapse';
    });

    // Mobile toggle
    document.getElementById('mobileBtn').addEventListener('click', function () {
        document.body.classList.toggle('mobile-open');
    });

    document.addEventListener('click', function (e) {
        if (document.body.classList.contains('mobile-open')) {
            var sb = document.getElementById('sidebar');
            var mb = document.getElementById('mobileBtn');
            if (!sb.contains(e.target) && e.target !== mb)
                document.body.classList.remove('mobile-open');
        }
    });

    // Logout confirm
    document.getElementById('sidebarLogout').addEventListener('click', function (e) {
        e.preventDefault();
        var href = this.href;
        Swal.fire({
            title: 'Logging out?',
            text: 'Are you sure you want to end this admin session?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#C0392B',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Yes, logout'
        }).then(function (r) { if (r.isConfirmed) window.location.href = href; });
    });

    // SweetAlert TempData
    var successMsg = '@TempData["SuccessMessage"]';
    var errorMsg   = '@TempData["Message"]';
    if (successMsg && successMsg.trim() !== '') {
        Swal.fire({ icon:'success', title:'Done!', text: successMsg, confirmButtonColor:'#C0392B', timer:2500, timerProgressBar:true });
    }
    if (errorMsg && errorMsg.trim() !== '') {
        Swal.fire({ icon:'info', title:'Notice', text: errorMsg, confirmButtonColor:'#C0392B', timer:2500 });
    }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
