@model MARS_Project.Models.Cart
@{
    ViewBag.Title = "Checkout";
    Layout = "~/Views/Shared/_LayoutCustomer.cshtml";
}

<style>
    .page-hero {
        background: linear-gradient(135deg, #1a0a08 0%, #C0392B 60%, #8B1A14 100%);
        padding: 48px 0 90px;
        position: relative;
        overflow: hidden;
    }

        .page-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.04) 1px,transparent 1px);
            background-size: 40px 40px;
        }

        .page-hero::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 60px;
            background: #f6f7fb;
            clip-path: ellipse(55% 100% at 50% 100%);
        }

    .hero-inner {
        position: relative;
        z-index: 2;
        text-align: center;
        color: #fff;
    }

        .hero-inner .page-label {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.6);
            margin-bottom: 6px;
        }

        .hero-inner h1 {
            font-size: 1.75rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 14px;
        }

    .hero-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 18px;
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 20px;
        color: #fff;
        font-size: 13px;
        text-decoration: none;
    }

        .hero-back-btn:hover {
            background: rgba(255,255,255,0.28);
            color: #fff;
        }

    .checkout-wrapper {
        max-width: 900px;
        margin: -55px auto 0;
        padding: 0 16px 60px;
        position: relative;
        z-index: 5;
    }

    /* Steps bar */
    .steps-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        margin-bottom: 24px;
    }

    .step {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .step-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
    }

        .step-circle.done {
            background: #C0392B;
            color: #fff;
        }

        .step-circle.active {
            background: #fff;
            color: #C0392B;
            border: 2px solid #C0392B;
        }

    .step-label {
        font-size: 12.5px;
        font-weight: 600;
        color: #fff;
    }

    .step-line {
        width: 60px;
        height: 2px;
        background: rgba(255,255,255,0.25);
        margin: 0 8px;
    }

    /* Cards */
    .c-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #eee;
        box-shadow: 0 8px 32px rgba(0,0,0,0.07);
        overflow: hidden;
        margin-bottom: 16px;
    }

    .c-card-header {
        padding: 15px 22px;
        border-bottom: 1px solid #f0f0f0;
        background: #fafafa;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .c-card-header .hicon {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg, #C0392B, #8B1A14);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 14px;
        }

        .c-card-header h5 {
            font-size: 14px;
            font-weight: 700;
            color: #1a1a2e;
            margin: 0;
        }

    .c-card-body {
        padding: 20px 22px;
    }

    /* Order items */
    .order-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 0;
        border-bottom: 1px solid #f5f5f5;
    }

        .order-item:last-child {
            border-bottom: none;
        }

        .order-item img {
            width: 58px;
            height: 58px;
            border-radius: 10px;
            object-fit: cover;
            border: 1px solid #eee;
            flex-shrink: 0;
        }

    .order-item-info {
        flex: 1;
        min-width: 0;
    }

    .order-item-name {
        font-size: 14px;
        font-weight: 600;
        color: #1a1a2e;
    }

    .order-item-qty {
        font-size: 12px;
        color: #aaa;
    }

    .order-item-price {
        font-size: 15px;
        font-weight: 700;
        color: #C0392B;
    }

    /* Form fields */
    .field-group {
        margin-bottom: 18px;
    }

        .field-group label {
            display: block;
            font-size: 11.5px;
            font-weight: 600;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.7px;
            margin-bottom: 7px;
        }

    .field-wrap {
        position: relative;
    }

        .field-wrap .f-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: #C0392B;
            font-size: 14px;
            pointer-events: none;
        }

        .field-wrap .f-icon-top {
            position: absolute;
            left: 13px;
            top: 13px;
            color: #C0392B;
            font-size: 14px;
            pointer-events: none;
        }

        .field-wrap input, .field-wrap textarea {
            width: 100%;
            padding: 11px 14px 11px 40px;
            border: 1.5px solid #e5e7eb;
            border-radius: 11px;
            font-size: 14px;
            color: #1a1a2e;
            background: #fdfdfd;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            font-family: 'DM Sans', sans-serif;
        }

        .field-wrap textarea {
            resize: none;
            height: 80px;
            padding-top: 11px;
        }

            .field-wrap input:focus, .field-wrap textarea:focus {
                border-color: #C0392B;
                box-shadow: 0 0 0 3px rgba(192,57,43,0.1);
                background: #fff;
            }

    .fields-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 18px;
    }

    .field-group.full {
        grid-column: 1/-1;
    }

    /* Summary total */
    .total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f5f5f5;
        font-size: 13.5px;
        color: #555;
    }

        .total-row:last-child {
            border-bottom: none;
        }

        .total-row.grand {
            font-size: 17px;
            font-weight: 700;
            color: #1a1a2e;
            padding-top: 14px;
        }

            .total-row.grand span:last-child {
                color: #C0392B;
            }

    .btn-place-order {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #C0392B, #8B1A14);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(192,57,43,0.3);
        transition: opacity 0.2s, transform 0.15s;
        margin-top: 16px;
    }

        .btn-place-order:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

    .secure-note {
        text-align: center;
        font-size: 12px;
        color: #bbb;
        margin-top: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }

        .secure-note i {
            color: #C0392B;
        }

    @@media (max-width:576px) {
        .page-hero {
            padding: 36px 0 80px;
        }

        .checkout-wrapper {
            margin-top: -50px;
        }

        .fields-grid {
            grid-template-columns: 1fr;
        }

        .field-group.full {
            grid-column: auto;
        }

        .c-card-body {
            padding: 16px;
        }

        .steps-bar {
            display: none;
        }
    }
</style>

<!-- Hero with steps -->
<div class="page-hero">
    <div class="container hero-inner">
        <div class="page-label">Order</div>
        <h1><i class="fa fa-credit-card me-2"></i>Checkout</h1>

        <div class="steps-bar">
            <div class="step">
                <div class="step-circle done"><i class="fa fa-check"></i></div>
                <span class="step-label">Cart</span>
            </div>
            <div class="step-line"></div>
            <div class="step">
                <div class="step-circle active">2</div>
                <span class="step-label">Checkout</span>
            </div>
            <div class="step-line"></div>
            <div class="step">
                <div class="step-circle" style="background:rgba(255,255,255,0.2);color:#fff;">3</div>
                <span class="step-label" style="opacity:0.6;">Confirm</span>
            </div>
        </div>

        <a href="@Url.Action("ViewCart","Cart")" class="hero-back-btn">
            <i class="fa fa-arrow-left"></i> Back to Cart
        </a>
    </div>
</div>

<!-- Content -->
<div class="checkout-wrapper">

    @if (Model == null || !Model.CartItems.Any())
    {
        <div class="c-card">
            <div class="c-card-body" style="text-align:center;padding:50px 24px;">
                <div style="width:72px;height:72px;background:#fef3f2;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;margin-bottom:16px;">
                    <i class="fa fa-cart-shopping" style="font-size:28px;color:#C0392B;"></i>
                </div>
                <h4 style="font-weight:700;color:#1a1a2e;margin-bottom:8px;">Cart is Empty</h4>
                <p style="color:#aaa;margin-bottom:20px;">Please add products before checkout.</p>
                <a href="@Url.Action("Index","CustomerProduct")" style="display:inline-flex;align-items:center;gap:7px;padding:11px 24px;background:linear-gradient(135deg,#C0392B,#8B1A14);color:#fff;border-radius:11px;text-decoration:none;font-weight:600;">
                    <i class="fa fa-arrow-left"></i> Back to Products
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Left: Customer info -->
            <div class="col-lg-7">
                <div class="c-card">
                    <div class="c-card-header">
                        <div class="hicon"><i class="fa fa-user"></i></div>
                        <h5>Delivery Information</h5>
                    </div>
                    <div class="c-card-body">
                        <div class="fields-grid">
                            <div class="field-group">
                                <label>Full Name</label>
                                <div class="field-wrap">
                                    <i class="fa fa-user f-icon"></i>
                                    <input type="text" placeholder="Your full name" value="@Session["UserName"]" readonly />
                                </div>
                            </div>
                            <div class="field-group">
                                <label>Phone Number</label>
                                <div class="field-wrap">
                                    <i class="fa fa-phone f-icon"></i>
                                    <input type="text" placeholder="03xx-xxxxxxx" />
                                </div>
                            </div>
                            <div class="field-group full">
                                <label>Delivery Address</label>
                                <div class="field-wrap">
                                    <i class="fa fa-map-marker-alt f-icon-top"></i>
                                    <textarea placeholder="Enter your delivery address..."></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Order Items -->
                <div class="c-card">
                    <div class="c-card-header">
                        <div class="hicon"><i class="fa fa-box"></i></div>
                        <h5>Order Items (@Model.CartItems.Count)</h5>
                    </div>
                    <div class="c-card-body">
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="order-item">
                                <img src="@Url.Content(string.IsNullOrEmpty(item.Product.ImageURL) ? "~/Content/Images/andoridePhon.jpg" : item.Product.ImageURL)"
                                     alt="@item.Product.Name" />
                                <div class="order-item-info">
                                    <div class="order-item-name">@item.Product.Name</div>
                                    <div class="order-item-qty">Qty: @item.Quantity</div>
                                </div>
                                <div class="order-item-price">Rs. @((item.Price * item.Quantity).ToString("N0"))</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right: Summary + Place Order -->
            <div class="col-lg-5">
                <div class="c-card">
                    <div class="c-card-header">
                        <div class="hicon"><i class="fa fa-receipt"></i></div>
                        <h5>Order Summary</h5>
                    </div>
                    <div class="c-card-body">
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="total-row">
                                <span>@item.Product.Name <span style="color:#aaa;font-size:12px;">x@item.Quantity</span></span>
                                <span>Rs. @((item.Price * item.Quantity).ToString("N0"))</span>
                            </div>
                        }
                        <div class="total-row grand">
                            <span>Grand Total</span>
                            <span>Rs. @Model.CartItems.Sum(x => x.Price * x.Quantity).ToString("N0")</span>
                        </div>

                        @using (Html.BeginForm("PlaceOrder", "Cart", FormMethod.Post))
                        {
                            <button type="submit" class="btn-place-order" id="btnPlaceOrder">
                                <i class="fa fa-check-circle"></i> Place Order
                            </button>
                        }

                        <div class="secure-note">
                            <i class="fa fa-shield-halved"></i>
                            Your order is safe and secure
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const form = document.querySelector("form");
        if (form) {
            form.addEventListener("submit", function (e) {
                e.preventDefault();
                Swal.fire({
                    title: "Confirm Order?",
                    text: "Are you sure you want to place this order?",
                    icon: "question",
                    showCancelButton: true,
                    confirmButtonColor: "#C0392B",
                    cancelButtonColor: "#6c757d",
                    confirmButtonText: "Yes, Place Order",
                    cancelButtonText: "Cancel"
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: "Processing...",
                            text: "Please wait while we confirm your order.",
                            icon: "info",
                            showConfirmButton: false,
                            allowOutsideClick: false,
                            didOpen: () => { Swal.showLoading(); }
                        });
                        setTimeout(() => { form.submit(); }, 1000);
                    }
                });
            });
        }
    });
</script>
