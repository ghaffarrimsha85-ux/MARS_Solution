@model IEnumerable<MARS_Project.Models.Order>
@{
    ViewBag.Title = "My Orders";
    Layout = "~/Views/Shared/_LayoutCustomer.cshtml";
    var hasCancelled = Model != null && Model.Any(o => o.Status == "Cancelled");
}

<style>
    .page-hero {
        background: linear-gradient(135deg, #1a0a08 0%, #C0392B 60%, #8B1A14 100%);
        padding: 48px 0 90px;
        position: relative;
        overflow: hidden;
    }

        .page-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.04) 1px,transparent 1px);
            background-size: 40px 40px;
        }

        .page-hero::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 60px;
            background: #f6f7fb;
            clip-path: ellipse(55% 100% at 50% 100%);
        }

    .hero-inner {
        position: relative;
        z-index: 2;
        text-align: center;
        color: #fff;
    }

        .hero-inner .page-label {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.6);
            margin-bottom: 6px;
        }

        .hero-inner h1 {
            font-size: 1.75rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 14px;
        }

    .hero-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 18px;
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 20px;
        color: #fff;
        font-size: 13px;
        text-decoration: none;
    }

        .hero-back-btn:hover {
            background: rgba(255,255,255,0.28);
            color: #fff;
        }

    .orders-wrapper {
        max-width: 820px;
        margin: -55px auto 0;
        padding: 0 16px 60px;
        position: relative;
        z-index: 5;
    }

    /* Action bar */
    .action-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 20px;
    }

        .action-bar .total-count {
            font-size: 13.5px;
            color: #888;
        }

            .action-bar .total-count strong {
                color: #1a1a2e;
            }

    .btn-delete-all {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 18px;
        background: #fef3f2;
        border: 1.5px solid rgba(192,57,43,0.25);
        border-radius: 10px;
        color: #C0392B;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-delete-all:hover {
            background: #C0392B;
            color: #fff;
            border-color: #C0392B;
        }

    /* Empty */
    .empty-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #eee;
        box-shadow: 0 8px 32px rgba(0,0,0,0.06);
        padding: 60px 24px;
        text-align: center;
    }

    .empty-icon {
        width: 80px;
        height: 80px;
        background: #fef3f2;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 18px;
    }

        .empty-icon i {
            font-size: 32px;
            color: #C0392B;
        }

    .empty-card h4 {
        font-size: 17px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 8px;
    }

    .empty-card p {
        font-size: 13.5px;
        color: #aaa;
        margin-bottom: 22px;
    }

    /* Order card */
    .order-card {
        background: #fff;
        border-radius: 18px;
        border: 1px solid #eee;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        overflow: hidden;
        margin-bottom: 14px;
        transition: box-shadow 0.2s;
    }

        .order-card:hover {
            box-shadow: 0 8px 28px rgba(0,0,0,0.09);
        }

    .order-card-top {
        height: 4px;
        width: 100%;
    }

        .order-card-top.pending {
            background: linear-gradient(90deg,#f39c12,#e67e22);
        }

        .order-card-top.completed {
            background: linear-gradient(90deg,#1a7a47,#27ae60);
        }

        .order-card-top.cancelled {
            background: linear-gradient(90deg,#c0392b,#e74c3c);
        }

        .order-card-top.other {
            background: linear-gradient(90deg,#95a5a6,#bdc3c7);
        }

    .order-card-body {
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .order-num {
        width: 52px;
        height: 52px;
        background: #fef3f2;
        border-radius: 13px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .order-num span:first-child {
            font-size: 9px;
            font-weight: 700;
            color: #C0392B;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .order-num span:last-child {
            font-size: 16px;
            font-weight: 700;
            color: #C0392B;
            line-height: 1;
        }

    .order-info {
        flex: 1;
        min-width: 180px;
    }

    .order-date {
        font-size: 12px;
        color: #aaa;
        display: flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 6px;
    }

        .order-date i {
            font-size: 11px;
            color: #C0392B;
        }

    .order-amount {
        font-size: 18px;
        font-weight: 700;
        color: #1a1a2e;
    }

        .order-amount span {
            font-size: 12px;
            font-weight: 500;
            color: #aaa;
            margin-left: 4px;
        }

    /* Status pill */
    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 700;
    }

        .status-pill.pending {
            background: #fff8e6;
            color: #b7770d;
            border: 1px solid #f5d87a;
        }

        .status-pill.completed {
            background: #e8f8f0;
            color: #1a7a47;
            border: 1px solid #b7e4cc;
        }

        .status-pill.cancelled {
            background: #fef3f2;
            color: #C0392B;
            border: 1px solid rgba(192,57,43,0.25);
        }

        .status-pill.other {
            background: #f4f4f4;
            color: #888;
            border: 1px solid #ddd;
        }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    .order-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .action-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1.5px solid #eee;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        cursor: pointer;
        text-decoration: none;
        transition: border-color 0.18s,background 0.18s,color 0.18s;
    }

        .action-btn.cancel-btn {
            color: #f39c12;
            border-color: #f5d87a;
        }

            .action-btn.cancel-btn:hover {
                background: #f39c12;
                border-color: #f39c12;
                color: #fff;
            }

        .action-btn.delete-btn {
            color: #C0392B;
            border-color: rgba(192,57,43,0.25);
        }

            .action-btn.delete-btn:hover {
                background: #C0392B;
                border-color: #C0392B;
                color: #fff;
            }

        .action-btn.view-btn {
            color: #2980b9;
            border-color: #aecbf5;
        }

            .action-btn.view-btn:hover {
                background: #2980b9;
                border-color: #2980b9;
                color: #fff;
            }

    .btn-shop {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 11px 24px;
        background: linear-gradient(135deg,#C0392B,#8B1A14);
        color: #fff;
        border-radius: 11px;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
    }

        .btn-shop:hover {
            opacity: 0.9;
            color: #fff;
        }

    @@media(max-width:576px) {
        .page-hero {
            padding: 36px 0 80px;
        }

        .orders-wrapper {
            margin-top: -50px;
        }

        .order-card-body {
            gap: 10px;
        }

        .action-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-delete-all {
            justify-content: center;
        }
    }
</style>

<!-- Hero -->
<div class="page-hero">
    <div class="container hero-inner">
        <div class="page-label">Orders</div>
        <h1><i class="fa fa-box me-2"></i>My Orders</h1>
        <a href="@Url.Action("Index","CustomerProduct")" class="hero-back-btn">
            <i class="fa fa-home"></i> Home
        </a>
    </div>
</div>

<!-- Content -->
<div class="orders-wrapper">

    <div class="action-bar">
        <div class="total-count">
            Total: <strong>@(Model?.Count() ?? 0) order@(Model?.Count() != 1 ? "s" : "")</strong>
        </div>
        @if (hasCancelled)
        {
            <button id="btnDeleteAll" class="btn-delete-all">
                <i class="fa fa-trash"></i> Delete All Cancelled
            </button>
        }
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-card">
            <div class="empty-icon"><i class="fa fa-box-open"></i></div>
            <h4>No Orders Yet</h4>
            <p>You haven't placed any orders. Start shopping and your orders will appear here.</p>
            <a href="@Url.Action("Index","CustomerProduct")" class="btn-shop">
                <i class="fa fa-arrow-left"></i> Back to Shop
            </a>
        </div>
    }
    else
    {
        foreach (var order in Model)
        {
            string sc = order.Status == "Pending" ? "pending"
                      : order.Status == "Completed" ? "completed"
                      : order.Status == "Cancelled" ? "cancelled" : "other";

            <div class="order-card">
                <div class="order-card-top @sc"></div>
                <div class="order-card-body">

                    <div class="order-num">
                        <span>ORD</span>
                        <span>#@order.OrderID</span>
                    </div>

                    <div class="order-info">
                        <div class="order-date">
                            <i class="fa fa-calendar"></i>
                            @(order.OrderDate.HasValue ? order.OrderDate.Value.ToString("MMM dd, yyyy · hh:mm tt") : "—")
                        </div>
                        <div class="order-amount">
                            Rs. @order.TotalAmount.ToString("N0")
                            <span>total</span>
                        </div>
                    </div>

                    <span class="status-pill @sc">
                        <span class="status-dot"></span>
                        @order.Status
                    </span>

                    <div class="order-actions">
                        @if (order.Status == "Pending")
                        {
                            <button type="button" class="action-btn cancel-btn btn-cancel" data-id="@order.OrderID" title="Cancel Order">
                                <i class="fa fa-times"></i>
                            </button>
                        }
                        else if (order.Status == "Cancelled")
                        {
                            <button type="button" class="action-btn delete-btn btn-delete" data-id="@order.OrderID" title="Delete Order">
                                <i class="fa fa-trash"></i>
                            </button>
                        }
                        <a href="@Url.Action("OrderDetails","Cart", new { id = order.OrderID })" class="action-btn view-btn" title="View Details">
                            <i class="fa fa-eye"></i>
                        </a>
                    </div>

                </div>
            </div>
        }
    }

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const cancelUrl    = '@Url.Action("CancelOrder","Cart")';
            const deleteUrl    = '@Url.Action("DeleteOrder","Cart")';
            const deleteAllUrl = '@Url.Action("DeleteAllOrders","Cart")';

            document.querySelectorAll('.btn-cancel').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const id = btn.getAttribute('data-id');
                    Swal.fire({
                        title: 'Cancel this order?',
                        text: 'You can place a new order later.',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, cancel it!',
                        confirmButtonColor: '#f39c12',
                        cancelButtonColor: '#6c757d'
                    }).then((res) => { if (res.isConfirmed) window.location = cancelUrl + '/' + id; });
                });
            });

            document.querySelectorAll('.btn-delete').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const id = btn.getAttribute('data-id');
                    Swal.fire({
                        title: 'Delete this order?',
                        text: 'This will permanently remove the order.',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, delete it!',
                        confirmButtonColor: '#C0392B',
                        cancelButtonColor: '#6c757d'
                    }).then((res) => { if (res.isConfirmed) window.location = deleteUrl + '/' + id; });
                });
            });

            const btnDeleteAll = document.getElementById('btnDeleteAll');
            if (btnDeleteAll) {
                btnDeleteAll.addEventListener('click', function () {
                    Swal.fire({
                        title: 'Delete all cancelled orders?',
                        text: 'This will permanently remove all cancelled orders.',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, delete all!',
                        confirmButtonColor: '#C0392B'
                    }).then((res) => { if (res.isConfirmed) window.location = deleteAllUrl; });
                });
            }

            var tempMsg = @Html.Raw(Json.Encode(TempData["Message"]));
            if (tempMsg) {
                Swal.fire({ icon: 'success', title: 'Done!', text: tempMsg, timer: 2000, showConfirmButton: false });
            }
        });
    </script>
}
